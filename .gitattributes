# =============================================================================
# .gitattributes — EPL Website Repo
# =============================================================================
# STRATEGY: Map .epl → Python (best available fallback until EPL is officially
# added to github-linguist/linguist). This gives syntax highlighting and shows
# a language bar. We vendor only the pure build tooling, not the EPL source.
# =============================================================================

# ── EPL source files ──────────────────────────────────────────────────────────
# linguist-language=Python  → temporary fallback; provides actual highlighting
#                             since Linguist does not yet know about EPL.
#                             Will be changed to "EPL" after the Linguist PR.
# linguist-detectable=true  → force Linguist to count these in the stats bar.
*.epl   linguist-language=Python
*.epl   linguist-detectable=true

# ── Python build tooling — exclude from language stats ────────────────────────
# These files only build/deploy the site; they are not the project source.
build.py            linguist-vendored=true
assets/make_og.py   linguist-vendored=true

# ── GitHub Actions — always excluded ─────────────────────────────────────────
.github/**          linguist-vendored=true
