Route "/privacy" shows
    Page "Privacy Policy — EPL"
        Description "Privacy Policy for EPL. How we collect, use, and protect your data. Payments processed by Razorpay and Lemon Squeezy."
        Stylesheet
                :root{--ink:#FFFFFF;--paper:#111113;--muted:#5F6066;--ink2:#2A2A2E;
                    --line:rgba(17,17,19,.1);--line-soft:rgba(17,17,19,.05);--accent:#007DF3;--navy:#0E1A32;
                    --gut:clamp(20px,5vw,44px);--logo:url("data:image/png;base64,")}
                *{box-sizing:border-box}
                html{scroll-behavior:smooth}
                body{margin:0;background:var(--ink);color:var(--paper);line-height:1.66;
                    font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
                    -webkit-font-smoothing:antialiased;letter-spacing:-.011em}
                .container{max-width:100%!important;margin:0!important;padding:0!important;width:100%}
                p{margin:0}
                a{color:var(--accent);text-decoration:none}
                a:hover{text-decoration:underline}
                ::selection{background:var(--paper);color:#fff}
                .lnav{position:sticky;top:0;z-index:10;display:flex;align-items:center;justify-content:space-between;
                    padding:16px var(--gut);border-bottom:1px solid var(--line-soft);
                    background:rgba(255,255,255,.82);backdrop-filter:saturate(160%) blur(14px)}
                .lbrand a{display:inline-flex;align-items:center;gap:10px;font-weight:800;font-size:20px;
                    letter-spacing:-.03em;color:var(--paper)}
                .lbrand a:hover{text-decoration:none}
                .lbrand a::before{content:'';width:26px;height:28px;background:var(--logo) center/contain no-repeat}
                .lnav-right{display:flex;align-items:center;gap:22px}
                .lnav-right > a{font-size:14px;font-weight:500;color:var(--muted)}
                .lnav-right > a:hover{color:var(--paper);text-decoration:none}
                .lnav-cta-wrap a{color:#fff;background:var(--paper);padding:9px 18px;border-radius:999px;font-weight:600;font-size:14px}
                .lnav-cta-wrap a:hover{background:var(--navy);text-decoration:none}
                .legal{max-width:760px;margin:0 auto;padding:clamp(46px,7vw,90px) var(--gut) 40px}
                .eyebrow{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:500;
                    letter-spacing:.28em;text-transform:uppercase;color:var(--accent)}
                .legal h1{font-size:clamp(2.1rem,5vw,3.2rem);font-weight:800;letter-spacing:-.035em;
                    line-height:1.04;margin:14px 0 8px;color:var(--paper)}
                .updated{color:var(--muted);font-size:14px;margin-bottom:18px}
                .intro{font-size:1.12rem;line-height:1.62;color:var(--ink2);margin-bottom:8px}
                .lh2{font-size:1.28rem;font-weight:700;letter-spacing:-.02em;margin:40px 0 12px;color:var(--paper)}
                .legal p{color:var(--ink2);font-size:1.02rem;margin:0 0 14px}
                .legal .ul{margin:4px 0 16px;display:flex;flex-direction:column;gap:9px}
                .legal .li{position:relative;padding-left:22px;color:var(--ink2);font-size:1.02rem;line-height:1.6}
                .legal .li::before{content:'';position:absolute;left:3px;top:.62em;width:7px;height:7px;
                    border-radius:50%;background:var(--accent)}
                .legal .li p{display:inline}
                .legal strong{color:var(--paper);font-weight:600}
                .box{background:#F6F6F7;border:1px solid var(--line);border-radius:14px;
                    padding:18px 22px;margin:8px 0 14px;color:var(--muted);font-size:.97rem}
                .box a{font-weight:600}
                .lfoot{border-top:1px solid var(--line);margin-top:24px;padding:38px var(--gut);
                    display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;
                    max-width:880px;margin-left:auto;margin-right:auto;color:var(--muted);font-size:13px}
                .lfoot a{color:var(--muted)}
                .lfoot-links{display:flex;gap:20px;flex-wrap:wrap}
                .lfoot p{display:inline}
                @media(max-width:560px){.lnav-right > a{display:none}}
                
        End
        Div class "lnav"
            Div class "lbrand"
                Link "EPL" to "/"
            End
            Div class "lnav-right"
                Link "Docs" to "https://abneeshsingh21.github.io/EPL/"
                Link "Back to site" to "/"
                Div class "lnav-cta-wrap"
                    Link "Install" to "/#install"
                End
            End
        End
        Div class "legal"

            Div class "eyebrow"
                Text "Legal · Effective 16 June 2026"
            End
            Heading "Privacy Policy"
            Div class "updated"
                Text "Last updated 16 June 2026"
            End
            Div class "intro"
                Text "This Privacy Policy explains how Abneesh Singh (referred to as EPL, we, or us) collects, uses, and protects your information when you use the EPL website and Services. We are an individual sole proprietor based in India and are committed to handling your data responsibly."
            End
            Div class "lh2"
                Text "1. Information we collect"
            End
            Div class "ul"
                Div class "li"
                    Text "Information you provide: such as your name and email address when you contact us, sponsor the project, or make a purchase."
                End
                Div class "li"
                    Text "Payment information: when you make a payment, it is collected and processed directly by our payment providers (Razorpay and Lemon Squeezy). We receive only limited transaction details, such as a confirmation, the amount, and partial identifiers; we do not store your full card or bank details."
                End
                Div class "li"
                    Text "Usage data: basic technical information such as browser type, device, and pages visited may be recorded through standard server logs or privacy-respecting analytics to operate and improve the site."
                End
                Div class "li"
                    Text "Cookies and local storage: we use only the minimal cookies or local storage needed for the site to function."
                End
            End
            Div class "lh2"
                Text "2. How we use your information"
            End
            Text "We use information to provide and operate the Services; to process payments and issue receipts; to respond to your enquiries; to meet legal, tax, and accounting obligations; and to maintain and improve the site. We do not sell your personal data."
            Div class "lh2"
                Text "3. Sharing of information"
            End
            Text "We share information only with: payment processors (Razorpay and Lemon Squeezy) to complete transactions; hosting and infrastructure providers that help us run the site; and government authorities where disclosure is required by law. These providers process your data under their own privacy and security commitments."
            Div class "lh2"
                Text "4. Data retention"
            End
            Text "We retain transaction and contact records only for as long as necessary to fulfil the purposes described in this Policy and to comply with legal and accounting requirements, after which they are deleted or anonymised."
            Div class "lh2"
                Text "5. Security"
            End
            Text "We apply reasonable technical and organisational measures to protect your information. However, no method of transmission over the internet or electronic storage is completely secure, and we cannot guarantee absolute security."
            Div class "lh2"
                Text "6. Your rights"
            End
            Text "You may request access to, correction of, or deletion of your personal data, or object to certain processing, by emailing us. We will respond within a reasonable time, subject to any legal retention obligations."
            Div class "lh2"
                Text "7. International transfers"
            End
            Text "Because we use international service providers (for example, Lemon Squeezy), your information may be processed in countries outside your own. We take appropriate steps to ensure your data remains protected."
            Div class "lh2"
                Text "8. Children"
            End
            Text "The Services are not directed to children under 18, and we do not knowingly collect personal data from them. If you believe a child has provided us data, please contact us and we will remove it."
            Div class "lh2"
                Text "9. Changes to this Policy"
            End
            Text "We may update this Policy from time to time. The Last updated date above reflects the most recent version. Continued use of the Services indicates acceptance of the updated Policy."
            Div class "lh2"
                Text "10. Contact"
            End
            Div class "box"
                Text "For privacy questions or data requests, email contact@eplang.me."
            End

        End
        Div class "lfoot"
            Span class "c"
                Text "© 2024–2026 Abneesh Singh · EPL · Apache-2.0"
            End
            Div class "lfoot-links"
                Link "Terms" to "/terms"
                Link "Privacy" to "/privacy"
                Link "Refund" to "/refund"
                Link "Contact" to "mailto:contact@eplang.me"
            End
        End
    End
End

