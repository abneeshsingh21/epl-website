                .lnav-right{display:flex;align-items:center;gap:22px}
                .lnav-right > a{font-size:14px;font-weight:500;color:var(--muted)}
                .lnav-right > a:hover{color:var(--paper);text-decoration:none}
                .lnav-cta-wrap a{color:#fff;background:var(--paper);padding:9px 18px;border-radius:999px;font-weight:600;font-size:14px}
                .lnav-cta-wrap a:hover{background:var(--navy);text-decoration:none}
                .legal{max-width:760px;margin:0 auto;padding:clamp(46px,7vw,90px) var(--gut) 40px}
                .eyebrow{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:500;
                    letter-spacing:.28em;text-transform:uppercase;color:var(--accent)}
                .legal h1{font-size:clamp(2.1rem,5vw,3.2rem);font-weight:800;letter-spacing:-.035em;
                    line-height:1.04;margin:14px 0 8px;color:var(--paper)}
                .updated{color:var(--muted);font-size:14px;margin-bottom:18px}
                .intro{font-size:1.12rem;line-height:1.62;color:var(--ink2);margin-bottom:8px}
                .lh2{font-size:1.28rem;font-weight:700;letter-spacing:-.02em;margin:40px 0 12px;color:var(--paper)}
                .legal p{color:var(--ink2);font-size:1.02rem;margin:0 0 14px}
                .legal .ul{margin:4px 0 16px;display:flex;flex-direction:column;gap:9px}
