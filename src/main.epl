Note: EPL — Flagship product site (v3, Google-Antigravity visual language). Authored in native EPL (Nav/Header/Section/Footer/Div/Span/Link/Text).
Note: White background, geometric sans (Inter), two-tone black+gray headings, dark code/terminal islands, giant footer wordmark.
Note: Signature motion: a multicolor EPL particle galaxy-vortex (canvas) behind a centered hero, scroll-reveal + stagger,
Note: count-up stats, spotlight + 3D-tilt cards, magnetic buttons, package marquee, scroll progress, hidey glass nav.
Note: Accessibility: focus-visible + full prefers-reduced-motion fallback. Page chrome injected via head Script (project pattern).

Create WebApp called epl_site

Head
    Description "EPL (English Programming Language) is a real, open-source programming language with plain-English syntax. Install with pip install eplang. Bytecode VM, LLVM-native compilation, and 725+ built-ins."
    ThemeColor "#FFFFFF"
    Meta "color-scheme" "light"
    Meta "robots" "index,follow"
    Favicon "favicon.ico"
    Font "Plus Jakarta Sans" weights "400;500;600;700;800"
    Font "Inter" weights "400;500;600;700"
    Font "JetBrains Mono" weights "400;500;700"
End

Route "/" shows
    Page "EPL — The English Programming Language"
        OpenGraph title "EPL — The English Programming Language" description "Write code the way you think. In plain English. A real language: VM, LLVM native, WASM, mobile — 725+ builtins." type "website"
        Twitter card "summary_large_image" title "EPL — The English Programming Language" description "Write code the way you think. In plain English. A real language with a bytecode VM, LLVM-native compilation, and 725+ built-ins."

        Stylesheet
                :root{
                    /* Antigravity light system — --ink = page background (white), --paper = primary text (near-black) */
                    --ink:#FFFFFF; --ink-2:#F6F6F7; --ink-3:#EFEFF1;
                    --paper:#111113; --paper-dim:#5F6066; --paper-faint:#8A8B92;
                    --line:rgba(17,17,19,.1); --line-soft:rgba(17,17,19,.05);
                    --muted:#6B6C73;
                    /* official EPL brand: navy + electric blue (from the logo) */
                    --navy:#0E1A32;
                    --c1:#007DF3; --c2:#2EA0FF; --c3:#5BB8FF; --c4:#0A52C0;
                    --accent:#007DF3; --accent-soft:rgba(0,125,243,.1);
                    /* dark tokens — remapped onto the code + terminal islands only */
                    --d-ink:#0B0B0D; --d-ink-2:#151517; --d-paper:#F2F2F4;
                    --d-paper-dim:rgba(242,242,244,.62); --d-paper-faint:rgba(242,242,244,.4);
                    --d-line:rgba(242,242,244,.13); --d-line-soft:rgba(242,242,244,.08);
                    --gut:clamp(20px,5vw,72px); --ease:cubic-bezier(.16,1,.3,1);
                    /* deliberate body type scale — two tiers + controlled measure, so every
                       paragraph on the page shares one rhythm instead of ad-hoc sizes */
                    --fs-body:1.0625rem; --lh-body:1.65;
                    --fs-body-sm:1rem; --lh-body-sm:1.62;
                    --measure:48ch; --measure-card:50ch;
                    /* display face — geometric, airy: the Antigravity headline signature */
                    --display:'Plus Jakarta Sans','Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
                    --logo:url("data:image/png;base64,");
                }
                *{box-sizing:border-box}
                html{scroll-behavior:smooth}
                /* visually-hidden (screen-reader / SEO only) */
                .sr-only{position:absolute!important;width:1px;height:1px;padding:0;margin:-1px;
                    overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
                body{margin:0;background:var(--ink);color:var(--paper);
                    font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
                    font-weight:400;line-height:1.5;-webkit-font-smoothing:antialiased;overflow-x:hidden;
                    font-feature-settings:'cv11','ss01';letter-spacing:-.011em}
                .container{max-width:100%!important;margin:0!important;padding:0!important;width:100%}
                p{margin:0}
                a{color:inherit;text-decoration:none}
                ::selection{background:var(--paper);color:var(--ink)}

                /* dark code + terminal islands: remap tokens to dark values (inherited by descendants) */
                .code,.term{--ink:var(--d-ink);--ink-2:var(--d-ink-2);
                    --paper:var(--d-paper);--paper-dim:var(--d-paper-dim);--paper-faint:var(--d-paper-faint);
                    --line:var(--d-line);--line-soft:var(--d-line-soft)}
                :focus-visible{outline:2px solid var(--accent);outline-offset:3px;border-radius:4px}

                /* two-tone heading helper (Antigravity signature) */
                .g{color:var(--muted)}

                /* shared scaffolding */
                .wrap{max-width:1200px;margin:0 auto;padding:0 var(--gut);position:relative;z-index:2}
                .eyebrow{display:inline-flex;align-items:center;gap:10px;font-family:'JetBrains Mono',monospace;
                    font-size:11px;font-weight:500;letter-spacing:.28em;text-transform:uppercase;color:var(--muted)}
                .eyebrow p{display:inline}
                .ping{width:7px;height:7px;border-radius:50%;background:var(--accent);display:inline-block;
                    box-shadow:0 0 0 0 var(--accent-soft);animation:ping 2.4s var(--ease) infinite}
                .ping p{display:none}
                @keyframes ping{0%{box-shadow:0 0 0 0 rgba(79,70,229,.45)}70%,100%{box-shadow:0 0 0 9px rgba(79,70,229,0)}}
                .serif{font-weight:600}
                .section{padding:clamp(72px,8vw,118px) 0;position:relative;z-index:2}
                .sec-head{margin-bottom:clamp(40px,6vw,72px)}
                .sec-h{font-family:var(--display);font-size:clamp(2.1rem,4.8vw,3.7rem);line-height:1.04;letter-spacing:-.03em;margin:18px 0 0;font-weight:600}
                /* typographic precision: balance headings (no ragged/orphan lines),
                   pretty-wrap body (no lone last word). Progressive — ignored where unsupported. */
                .sec-h,.lead,.cta-h{text-wrap:balance}
                .hero-sub,.split-p,.pillar-desc,.audience-desc,.cta-sub,.foot-tag{text-wrap:pretty}

                /* reveal system — varied, premium entrances with a blur-focus finish */
                .reveal{opacity:0;transform:translateY(28px) scale(.986);filter:blur(1.5px);
                    transition:opacity .7s var(--ease),transform .8s var(--ease),filter .5s var(--ease)}
                .reveal.in{opacity:1;transform:none;filter:none}
                .reveal.r-left{transform:translateX(-46px) scale(.99)}
                .reveal.r-right{transform:translateX(46px) scale(.99)}
                .reveal.r-scale{transform:translateY(16px) scale(.9)}
                .reveal.r-zoom{transform:translateY(34px) scale(1.05)}
                .reveal.r-rise{transform:translateY(66px)}
                .reveal.r-left.in,.reveal.r-right.in,.reveal.r-scale.in,.reveal.r-zoom.in,.reveal.r-rise.in{transform:none}
                .dly-1{transition-delay:.06s}.dly-2{transition-delay:.12s}.dly-3{transition-delay:.18s}
                .dly-4{transition-delay:.24s}.dly-5{transition-delay:.3s}.dly-6{transition-delay:.36s}

                /* scroll progress + nav */
                .scroll-progress{position:fixed;top:0;left:0;right:0;height:2px;z-index:120;
                    background:linear-gradient(90deg,var(--c1),var(--c2),var(--c3));
                    transform:scaleX(0);transform-origin:0 50%;will-change:transform}
                .nav{position:fixed;top:0;left:0;right:0;z-index:90;
                    display:flex;align-items:center;justify-content:space-between;
                    padding:20px var(--gut);transition:padding .35s var(--ease),background .35s,border-color .35s,transform .45s var(--ease);
                    border-bottom:1px solid transparent}
                .nav.scrolled{padding:12px var(--gut);background:rgba(255,255,255,.82);
                    backdrop-filter:saturate(160%) blur(16px);border-bottom:1px solid var(--line-soft)}
                .nav.hidden{transform:translateY(-104%)}
                .nav-brand a{display:inline-flex;align-items:center;gap:10px;font-family:var(--display);font-weight:700;font-size:20px;
                    letter-spacing:-.02em;color:var(--paper)}
                .nav-brand a::before{content:'';width:26px;height:28px;
                    background:var(--logo) center/contain no-repeat}
                .nav-links{display:flex;align-items:center;gap:34px}
                .nav-links a{position:relative;font-size:14.5px;font-weight:500;color:var(--paper-dim);transition:color .25s}
                .nav-links a::after{content:'';position:absolute;left:0;bottom:-5px;height:2px;width:0;border-radius:2px;
                    background:var(--accent);transition:width .3s var(--ease)}
                .nav-links a:hover{color:var(--paper)}
                .nav-links a:hover::after{width:100%}
                .nav-cta-wrap a{font-size:14px;color:#FFF;background:var(--paper);
                    padding:10px 20px;border-radius:999px;font-weight:600;display:inline-block;
                    transition:transform .25s var(--ease),box-shadow .25s}
                .nav-cta-wrap a:hover{transform:translateY(-1px);box-shadow:0 10px 30px -10px rgba(17,17,19,.4)}
                /* mobile nav toggle (hidden on desktop) */
                .nav-toggle{display:none;flex-direction:column;justify-content:center;gap:5px;width:42px;height:42px;
                    cursor:pointer;border-radius:10px;position:relative;z-index:96}
                .nav-toggle-bar{display:block;width:22px;height:2px;margin:0 auto;border-radius:2px;background:var(--paper);
                    transition:transform .3s var(--ease),opacity .25s}
                .nav-toggle p{display:none}
                .nav.open .nav-toggle-bar:nth-child(1){transform:translateY(7px) rotate(45deg)}
                .nav.open .nav-toggle-bar:nth-child(2){opacity:0}
                .nav.open .nav-toggle-bar:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
                /* skip-to-content link (revealed on keyboard focus) */
                .skip-link-wrap a{position:fixed;top:-64px;left:12px;z-index:200;background:var(--paper);color:#fff;
                    padding:11px 18px;border-radius:9px;font-size:14px;font-weight:600;
                    transition:top .25s var(--ease)}
                .skip-link-wrap a:focus{top:12px;outline:2px solid var(--accent);outline-offset:2px}
                @media(max-width:860px){
                    .nav-toggle{display:flex}
                    .nav-links{display:flex;position:fixed;top:0;right:0;bottom:0;width:min(80vw,330px);
                        flex-direction:column;align-items:flex-start;gap:6px;padding:92px 28px 28px;
                        background:rgba(255,255,255,.97);backdrop-filter:saturate(160%) blur(18px);
                        border-left:1px solid var(--line-soft);box-shadow:-24px 0 60px -30px rgba(17,17,19,.35);
                        transform:translateX(105%);transition:transform .42s var(--ease);z-index:95}
                    .nav.open .nav-links{transform:translateX(0)}
                    .nav-links a{font-size:17px;padding:8px 0}
                }

                /* hero — centered composition */
                .hero{min-height:100vh;min-height:100svh;display:flex;flex-direction:column;align-items:center;justify-content:center;
                    text-align:center;padding:150px var(--gut) 90px;position:relative;overflow:hidden;isolation:isolate}
                .orbital{position:absolute;inset:0;z-index:0;pointer-events:none}
                .hero::after{content:'';position:absolute;inset:0;z-index:0;pointer-events:none;
                    background:radial-gradient(620px circle at var(--hx,50%) var(--hy,46%),rgba(124,58,237,.07),transparent 62%)}
                /* aurora: slow drifting gradient-mesh glow for depth behind the particles */
                .hero::before{content:'';position:absolute;inset:-15% -10% 0;z-index:0;pointer-events:none;
                    background:
                        radial-gradient(38% 44% at 22% 30%,rgba(0,125,243,.10),transparent 70%),
                        radial-gradient(34% 40% at 80% 26%,rgba(124,92,255,.09),transparent 70%),
                        radial-gradient(40% 38% at 62% 76%,rgba(46,160,255,.07),transparent 72%);
                    filter:blur(8px);opacity:.9;animation:hero-aurora 22s ease-in-out infinite alternate}
                @keyframes hero-aurora{
                    0%{transform:translate3d(0,0,0) scale(1)}
                    50%{transform:translate3d(-2.5%,1.5%,0) scale(1.06)}
                    100%{transform:translate3d(2%,-1%,0) scale(1.03)}
                }
                .hero-grain{display:none}
                .hero > *:not(.orbital):not(.hero-scroll){position:relative;z-index:2}
                .hero-eyebrow{margin-bottom:30px}
                .hero-lockup{display:inline-flex;align-items:center;gap:13px;font-family:var(--display);font-weight:700;
                    font-size:clamp(22px,3vw,30px);letter-spacing:-.02em;margin-bottom:24px;color:var(--paper)}
                .hero-lockup::before{content:'';width:clamp(30px,4vw,40px);height:clamp(34px,4.6vw,46px);
                    background:var(--logo) center/contain no-repeat}
                .hero-badge{display:inline-flex;align-items:center;gap:9px;font-family:'JetBrains Mono',monospace;
                    font-size:12px;color:var(--paper-dim);background:var(--ink);border:1px solid var(--line);
                    padding:7px 15px;border-radius:999px;box-shadow:0 2px 10px -4px rgba(17,17,19,.08)}
                .hero-badge p{display:inline}
                .hero-h{font-family:var(--display);font-weight:500;font-size:clamp(2.9rem,7.6vw,6.2rem);line-height:1.04;letter-spacing:-.035em;
                    margin:0;max-width:16ch;color:var(--paper)}
                /* signature gravity-fall — each word drops from above and settles into
                   place: the antigravity motif applied to the headline itself. Staggered
                   so the sentence assembles word by word. Static under reduced-motion. */
                .hero-h .w{display:inline-block;opacity:0;transform:translateY(-.72em);
                    animation:hero-gfall 1.05s var(--ease) both;will-change:transform}
                .hero-h .w:nth-child(1){animation-delay:.06s}
                .hero-h .w:nth-child(2){animation-delay:.2s}
                .hero-h .w:nth-child(3){animation-delay:.34s}
                .hero-h .w:nth-child(4){animation-delay:.48s}
                .hero-h .w:nth-child(5){animation-delay:.62s}
                .hero-h .w:nth-child(6){animation-delay:.76s}
                @keyframes hero-gfall{
                    0%{opacity:0;transform:translateY(-.72em)}
                    60%{opacity:1;transform:translateY(.055em)}
                    100%{opacity:1;transform:translateY(0)}}
                @media(prefers-reduced-motion:reduce){
                    .hero-h .w{opacity:1;transform:none;animation:none}}
                /* hero cascade choreography — the badge sets the stage first, then the
                   headline falls (~1.8s), then the sub/buttons/meta settle right as it
                   lands, so the whole hero comes to rest as one gravity-driven sequence.
                   Supporting elements rise from below (opposite the fall) to preserve
                   the headline's visual hierarchy. Two-class specificity beats .dly-*. */
                .hero-badge.reveal{transition-delay:.12s}
                .hero-sub.reveal{transition-delay:.9s}
                .btn-row.reveal{transition-delay:1.08s}
                .hero-meta.reveal{transition-delay:1.24s}
                .hero-h .g{background:linear-gradient(100deg,#007DF3 0%,#2EA0FF 22%,#7C5CFF 48%,#2EA0FF 74%,#007DF3 100%);
                    background-size:220% 100%;-webkit-background-clip:text;background-clip:text;color:transparent;
                    -webkit-text-fill-color:transparent;animation:hero-flow 9s linear infinite}
                @keyframes hero-flow{to{background-position:220% 0}}
                .hero-sub{margin:32px auto 0;max-width:52ch;font-size:clamp(1.08rem,1.5vw,1.35rem);
                    line-height:var(--lh-body);color:var(--paper-dim);font-weight:400}
                .btn-row{display:flex;align-items:center;justify-content:center;gap:14px;flex-wrap:wrap;margin-top:40px}
                .btn-row a{display:inline-flex;align-items:center;gap:10px;font-weight:600;font-size:15.5px;
                    padding:15px 26px;border-radius:999px;will-change:transform;
                    transition:transform .3s var(--ease),gap .3s var(--ease),background .3s,box-shadow .3s,border-color .3s}
                .btn-row a:first-child{position:relative;overflow:hidden;color:#FFF;
                    background:linear-gradient(120deg,#0A52C0 0%,#007DF3 42%,#2EA0FF 100%);
                    box-shadow:0 18px 40px -18px rgba(0,125,243,.6)}
                .btn-row a:first-child::after{content:'';position:absolute;top:0;left:-60%;width:45%;height:100%;
                    background:linear-gradient(105deg,transparent,rgba(255,255,255,.55),transparent);
                    transform:skewX(-18deg);transition:left .6s var(--ease);pointer-events:none}
                .btn-row a:first-child:hover{gap:15px;transform:translateY(-2px);
                    box-shadow:0 26px 58px -16px rgba(0,125,243,.7)}
                .btn-row a:first-child:hover::after{left:130%}
                .btn-row a:nth-child(2){border:1px solid var(--line);color:var(--paper);background:var(--ink)}
                .btn-row a:nth-child(2):hover{border-color:var(--paper);transform:translateY(-2px)}
                .hero-meta{display:flex;justify-content:center;gap:26px;flex-wrap:wrap;margin-top:42px;
                    font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--paper-faint);letter-spacing:.03em}
                .hero-meta p{display:inline}
                .hero-scroll{position:absolute;left:50%;bottom:34px;transform:translateX(-50%);z-index:3;
                    width:24px;height:40px;border:2px solid color-mix(in srgb,var(--paper) 30%,transparent);
                    border-radius:999px;opacity:.85;animation:hero-scroll-fade 4s ease-in-out infinite}
                .hero-scroll::before{content:'';position:absolute;left:50%;top:8px;width:4px;height:8px;border-radius:999px;
                    background:var(--accent);transform:translateX(-50%);
                    animation:hero-scroll-dot 1.9s var(--ease) infinite}
                @keyframes hero-scroll-dot{0%{opacity:0;transform:translate(-50%,0)}
                    25%{opacity:1}60%{opacity:1}100%{opacity:0;transform:translate(-50%,14px)}}
                @keyframes hero-scroll-fade{0%,100%{opacity:.85}50%{opacity:.45}}

                /* stats */
                .stats{display:grid;grid-template-columns:repeat(4,1fr);
                    border-top:1px solid var(--line);border-bottom:1px solid var(--line);position:relative;z-index:2}
                .stat{padding:clamp(36px,5vw,60px) 28px;border-left:1px solid var(--line-soft);text-align:center}
                .stat:first-child{border-left:none}
                .stat-num{font-family:var(--display);font-weight:600;font-size:clamp(2.5rem,5.2vw,3.8rem);letter-spacing:-.035em;line-height:1;
                    color:var(--paper);font-variant-numeric:tabular-nums}
                .stat-label{margin-top:13px;font-size:13.5px;color:var(--paper-dim);line-height:1.45}
                @media(max-width:780px){.stats{grid-template-columns:1fr 1fr}
                    .stat{border-left:none}.stat:nth-child(even){border-left:1px solid var(--line-soft)}}
                /* very narrow phones (≤360px): the large tabular stat numbers blow out the
                   two-column cells. min-width:0 lets the columns hold their track and the
                   tighter side padding gives the numbers room so the page still fits. */
                @media(max-width:360px){.stats > *{min-width:0}.stat{padding-left:16px;padding-right:16px}}

                /* manifesto */
                .manifesto{max-width:1000px}
                .lead{font-family:var(--display);font-size:clamp(1.85rem,4.2vw,3.2rem);line-height:1.22;letter-spacing:-.025em;color:var(--paper);font-weight:500}
                .lead .italic-serif{color:var(--muted);font-weight:500}

                /* split + code */
                .split{display:grid;grid-template-columns:.82fr 1.18fr;gap:clamp(40px,6vw,92px);align-items:center}
                /* grid children default to min-width:auto, which lets the non-wrapping
                   code island + long copy blow the column (and the page) wider than the
                   viewport on mobile. min-width:0 bounds them: text wraps, the code island
                   scrolls inside its own .code-body (overflow-x:auto) instead of overflowing. */
                .split > *{min-width:0}
                .split-p{font-size:var(--fs-body);line-height:var(--lh-body);color:var(--paper-dim);max-width:var(--measure);margin-top:24px}
                .split-list{margin-top:30px;display:flex;flex-direction:column;gap:16px}
                .split-list .li{font-size:14.5px;color:var(--paper-dim);line-height:1.55;padding-left:24px;position:relative}
                .split-list .li::before{content:'';position:absolute;left:0;top:7px;width:9px;height:9px;border-radius:50%;
                    background:linear-gradient(135deg,var(--c1),var(--c2))}
                .split-list .li p{display:inline}
                /* On mobile the aurora .glow::before (inset:-20% horizontally) bleeds past
                   the narrow single-column section and widens the page. overflow-x:clip cuts
                   the horizontal escape only — the vertical glow bleed and desktop layout are
                   untouched, and unlike overflow:hidden it creates no scroll container. */
                @media(max-width:820px){.split{grid-template-columns:1fr;gap:38px}.section{overflow-x:clip}}

                /* aurora glow — soft rainbow bleed behind product cards (Antigravity signature).
                   Must sit on a NON-clipping wrapper (the card itself uses overflow:hidden). */
                .glow{position:relative;isolation:isolate}
                .glow::before{content:'';position:absolute;inset:-24% -20% -30%;z-index:-1;border-radius:44px;background:conic-gradient(from 210deg at 50% 48%, #2EA0FF, #7C5CFF, #FF5C7A, #FF9F45, #FFD23F, #21C7A8, #2EA0FF);filter:blur(70px) saturate(116%);opacity:.66;transform:translate3d(0,var(--gy,0px),0);transition:opacity .6s var(--ease)}
                .glow:hover::before{opacity:.86}

                .code{background:var(--d-ink);border:1px solid var(--line);
                    border-radius:18px;overflow:hidden;box-shadow:0 40px 100px -50px rgba(17,17,19,.4);position:relative}
                .code::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;z-index:1;
                    background:linear-gradient(90deg,var(--c1),var(--c2),var(--c3))}
                .code-bar{display:flex;align-items:center;gap:8px;padding:15px 18px;border-bottom:1px solid var(--line-soft)}
                .dot{width:11px;height:11px;border-radius:50%;background:var(--line)}.dot p{display:none}
                .code-file{margin-left:12px;font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--paper-faint)}
                .code-file p{display:inline}
                .code-body{padding:26px 28px;font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.65;overflow-x:auto}
                /* flex row drops the inter-<span> whitespace the generator emits;
                   white-space:pre on the <p> keeps code indentation intact. */
                .code-body p{display:inline;margin:0;white-space:pre}
                .cline{display:flex;flex-wrap:nowrap;align-items:baseline;min-height:1.65em}
                .c-kw{color:#C4B5FD}.c-fn{color:#93C5FD}.c-str{color:#FCD34D}.c-id{color:var(--d-paper)}.c-dim{color:var(--d-paper-faint)}
                .c-num{color:#FBBF77}

                /* ── Interactive IDE walkthrough ── install ▸ write ▸ run, EPL-accurate ── */
                .ide-shell{max-width:1080px;margin:0 auto}
                /* skin variables — VS Code (default) vs Antigravity, swapped by .antigravity */
                .ide{--ide-bg:#1E1E1E;--ide-chrome:#181818;--ide-bar:#2C2C2C;--ide-side:#181818;
                    --ide-panel:#1E1E1E;--ide-line:rgba(255,255,255,.07);--ide-txt:#CCCCCC;
                    --ide-dim:#8A8A8A;--ide-faint:#6A6A6A;--ide-acc:#007ACC;--ide-acc-2:#0E639C;
                    --ide-active:#37373D;--ide-tabbg:#1E1E1E;
                    position:relative;border:1px solid var(--ide-line);border-radius:14px;overflow:hidden;
                    background:var(--ide-bg);box-shadow:0 50px 120px -55px rgba(17,17,19,.55);
                    font-family:'JetBrains Mono',monospace}
                .ide.antigravity{--ide-bg:#0F1115;--ide-chrome:#0B0D11;--ide-bar:#15181E;--ide-side:#0B0D11;
                    --ide-panel:#0F1115;--ide-line:rgba(255,255,255,.06);--ide-txt:#D6DAE2;
                    --ide-dim:#8B92A1;--ide-faint:#5E6573;--ide-acc:#3B82F6;--ide-acc-2:#2563EB;
                    --ide-active:#1B2027;--ide-tabbg:#0F1115}
                .ide::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;z-index:5;
                    background:linear-gradient(90deg,var(--c1),var(--c2),var(--c3))}
                /* title bar */
                .ide-title{display:flex;align-items:center;gap:12px;height:38px;padding:0 14px;
                    background:var(--ide-chrome);border-bottom:1px solid var(--ide-line);position:relative;z-index:2}
                .ide-dots{display:flex;gap:7px}
                .ide-dots i{width:11px;height:11px;border-radius:50%;display:block}
                .ide-dots i:nth-child(1){background:#FF5F57}.ide-dots i:nth-child(2){background:#FEBC2E}.ide-dots i:nth-child(3){background:#28C840}
                .ide-name{display:flex;align-items:center;gap:8px;margin:0 auto;font-size:11.5px;color:var(--ide-dim);letter-spacing:.01em}
                .ide-name p{display:inline}
                .ide-mark{width:16px;height:16px;flex:none}
                .ide-vsmark{display:inline-flex}.ide-agmark{display:none}
                .ide.antigravity .ide-vsmark{display:none}.ide.antigravity .ide-agmark{display:inline-flex}
                .skin-toggle{display:inline-flex;align-items:center;gap:0;background:rgba(255,255,255,.05);
                    border:1px solid var(--ide-line);border-radius:8px;padding:2px;cursor:pointer}
                .skin-opt{font-size:10.5px;letter-spacing:.02em;color:var(--ide-dim);padding:4px 10px;border-radius:6px;
                    transition:color .2s,background .2s;white-space:nowrap}
                .skin-opt p{display:inline}
                .ide:not(.antigravity) .skin-opt[data-skin="vscode"],
                .ide.antigravity .skin-opt[data-skin="antigravity"]{color:#fff;background:var(--ide-acc)}
                /* body grid: activity bar | side panel | main(editor+terminal) */
                .ide-body{display:grid;grid-template-columns:48px 230px 1fr;min-height:430px}
                .ide-act{background:var(--ide-side);border-right:1px solid var(--ide-line);
                    display:flex;flex-direction:column;align-items:center;gap:4px;padding:10px 0}
                .ide-ai{width:46px;height:42px;display:flex;align-items:center;justify-content:center;color:var(--ide-faint);
                    border-left:2px solid transparent;transition:color .25s,border-color .25s;position:relative}
                .ide-ai svg{width:23px;height:23px;stroke:currentColor;fill:none;stroke-width:1.5}
                .ide-ai.on{color:#fff;border-left-color:var(--ide-txt)}
                .ide-ai.pulse{color:#fff;border-left-color:var(--ide-acc)}
                .ide-ai.pulse::after{content:'';position:absolute;inset:6px 4px;border-radius:8px;
                    box-shadow:0 0 0 2px var(--ide-acc);opacity:0;animation:ide-pulse 1.4s var(--ease) infinite}
                @keyframes ide-pulse{0%{opacity:.7;transform:scale(.9)}70%{opacity:0;transform:scale(1.15)}100%{opacity:0}}
                .ide-ai .ai-badge{position:absolute;top:6px;right:6px;min-width:14px;height:14px;border-radius:7px;
                    background:var(--ide-acc);color:#fff;font-size:8.5px;display:flex;align-items:center;justify-content:center;padding:0 3px}
                /* side panel */
                .ide-side{background:var(--ide-side);border-right:1px solid var(--ide-line);overflow:hidden;color:var(--ide-txt)}
                .side-head{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--ide-dim);padding:13px 15px 9px}
                .side-head p{display:inline}
                .side-pane{display:none;animation:ide-fade .35s var(--ease)}
                .side-pane.show{display:block}
                @keyframes ide-fade{from{opacity:0}to{opacity:1}}
                /* extensions pane */
                .ext-search{margin:0 12px 6px;display:flex;align-items:center;gap:7px;background:var(--ide-bg);
                    border:1px solid var(--ide-line);border-radius:5px;padding:6px 9px;font-size:11.5px;color:var(--ide-txt)}
                .ext-search svg{width:13px;height:13px;stroke:var(--ide-dim);fill:none;stroke-width:1.6;flex:none}
                .ext-search .ext-q{min-height:1em}.ext-search .ext-q::after{content:'';display:inline-block;width:1px;height:1.05em;
                    background:var(--ide-acc);vertical-align:text-bottom;margin-left:1px;animation:demo-blink 1s steps(2,end) infinite}
                .ext-note{font-size:10px;line-height:1.5;color:var(--ide-faint);padding:2px 14px 8px}
                .ext-note p{display:inline}.ext-note b{color:var(--ide-dim);font-weight:500}
                .ext-card{margin:2px 8px;padding:10px;border-radius:8px;display:flex;gap:10px;
                    border:1px solid transparent;transition:background .25s,border-color .25s}
                .ext-card.sel{background:var(--ide-active);border-color:var(--ide-line)}
                .ext-logo{width:38px;height:38px;border-radius:7px;flex:none;background:#fff;
                    display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1px;
                    font-weight:800;letter-spacing:.02em;line-height:1}
                .ext-logo b{color:#0E1A32;font-size:8px}.ext-logo i{color:var(--accent);font-style:normal;font-size:12px;letter-spacing:.04em}
                .ext-meta{min-width:0;flex:1}
                .ext-tt{font-size:12px;font-weight:600;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-family:Inter,sans-serif}
                .ext-tt p{display:inline}
                .ext-desc{font-size:10px;line-height:1.45;color:var(--ide-dim);margin:2px 0 5px;
                    display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;font-family:Inter,sans-serif}
                .ext-desc p{display:inline}
                .ext-row{display:flex;align-items:center;gap:8px}
                .ext-pub{font-size:10px;color:var(--ide-dim);font-family:Inter,sans-serif}.ext-pub p{display:inline}
                .ext-stars{color:#F5C518;font-size:10px;letter-spacing:1px}
                .ext-install{margin-left:auto;font-size:10.5px;font-weight:600;color:#fff;background:var(--ide-acc-2);
                    border-radius:4px;padding:3px 11px;font-family:Inter,sans-serif;transition:transform .15s var(--ease),background .25s}
                .ext-install p{display:inline}
                .ext-install.press{transform:scale(.93)}
                .ext-install.done{background:transparent;color:var(--ide-dim);padding-left:0}
                /* explorer pane */
                .exp-row{display:flex;align-items:center;gap:6px;padding:3px 14px;font-size:12px;color:var(--ide-txt);font-family:Inter,sans-serif}
                .exp-row p{display:inline}
                .exp-row.ind{padding-left:28px}.exp-row.ind2{padding-left:40px}
                .exp-row.file{cursor:default}.exp-row.file.active{background:var(--ide-active)}
                .exp-row svg{width:14px;height:14px;flex:none;stroke:var(--ide-dim);fill:none;stroke-width:1.5}
                .exp-row.file .fz{width:13px;height:13px;border-radius:3px;background:var(--accent);flex:none}
                /* main column */
                .ide-main{display:flex;flex-direction:column;min-width:0;background:var(--ide-bg)}
                .ide-tabs{display:flex;align-items:center;height:36px;background:var(--ide-chrome);border-bottom:1px solid var(--ide-line)}
                .ide-tab{display:flex;align-items:center;gap:7px;height:100%;padding:0 15px;font-size:11.5px;color:var(--ide-dim);
                    background:var(--ide-chrome);border-right:1px solid var(--ide-line)}
                .ide-tab.active{color:#fff;background:var(--ide-tabbg);border-top:1px solid var(--ide-acc)}
                .ide-tab p{display:inline}.ide-tab .fz{width:12px;height:12px;border-radius:3px;background:var(--accent);flex:none}
                .ide-editor{flex:1;display:flex;font-size:13px;line-height:1.72;overflow:auto;min-height:170px}
                .ide-gutter{padding:16px 0 16px;text-align:right;color:var(--ide-faint);user-select:none;
                    min-width:42px;background:var(--ide-bg)}
                .ide-gutter span{display:block;padding:0 12px 0 0}
                .ide-code{padding:16px 18px;color:var(--ide-txt);flex:1;white-space:pre;overflow-x:auto}
                .ide-code .cline{display:block;min-height:1.72em}
                .ide-ghost{color:var(--ide-faint);font-style:italic}
                .demo-caret{display:inline-block;width:7px;height:1.02em;vertical-align:text-bottom;
                    background:var(--ide-acc);margin-left:1px;border-radius:1px;animation:demo-blink 1s steps(2,end) infinite}
                @keyframes demo-blink{50%{opacity:0}}
                /* terminal */
                .ide-term{border-top:1px solid var(--ide-line);background:var(--ide-panel);display:flex;flex-direction:column;min-height:150px}
                .term-tabs{display:flex;align-items:center;gap:18px;height:32px;padding:0 16px;border-bottom:1px solid var(--ide-line)}
                .term-tabs span{font-size:10px;letter-spacing:.12em;color:var(--ide-faint);text-transform:uppercase}
                .term-tabs span.on{color:var(--ide-txt);box-shadow:inset 0 -2px 0 var(--ide-acc);padding-bottom:7px}
                .term-body{padding:12px 16px;font-size:12px;line-height:1.7;color:var(--ide-txt);flex:1;overflow:auto}
                .term-line{white-space:pre-wrap;animation:demo-rise .25s var(--ease) both}
                .term-prompt{color:#4EC9B0}.term-cmd{color:#fff}.term-ok{color:#7FBF7F}.term-dim{color:var(--ide-dim)}
                .term-caret::after{content:'';display:inline-block;width:7px;height:1em;background:var(--ide-acc);
                    vertical-align:text-bottom;margin-left:2px;animation:demo-blink 1s steps(2,end) infinite}
                @keyframes demo-rise{from{opacity:0;transform:translateY(3px)}to{opacity:1;transform:none}}
                /* step rail (chapters) */
                .ide-rail{display:flex;gap:10px;max-width:1080px;margin:20px auto 0;flex-wrap:wrap;justify-content:center}
                .rail-step{flex:1 1 180px;max-width:250px;text-align:left;cursor:pointer;padding:13px 15px;border-radius:12px;
                    background:var(--ink-2);border:1px solid var(--line);transition:border-color .3s,background .3s,transform .2s var(--ease)}
                .rail-step:hover{transform:translateY(-2px)}
                .rail-step.active{border-color:var(--accent);background:#fff;box-shadow:0 14px 40px -22px var(--accent)}
                .rail-n{display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:50%;
                    font-size:11px;font-weight:700;color:var(--paper-dim);background:var(--line);margin-bottom:8px;font-family:'JetBrains Mono',monospace}
                .rail-step.active .rail-n{background:var(--accent);color:#fff}
                .rail-step.done .rail-n{background:#16A34A;color:#fff}
                .rail-t{font-size:13px;font-weight:600;color:var(--paper);margin-bottom:3px}
                .rail-t p{display:inline}
                .rail-d{font-size:11.5px;line-height:1.45;color:var(--paper-dim)}.rail-d p{display:inline}
                .rail-d code{font-family:'JetBrains Mono',monospace;font-size:10.5px;background:var(--ink-2);
                    border:1px solid var(--line);border-radius:4px;padding:1px 5px;color:var(--accent)}
                .ide-foot{text-align:center;margin-top:18px;font-size:13.5px;color:var(--paper-dim)}
                .ide-foot p{display:inline}.ide-foot a{color:var(--accent);font-weight:500}
                .ide-fallback{padding:34px 30px;font-size:13px;line-height:1.85;color:var(--d-paper-dim);
                    font-family:'JetBrains Mono',monospace}

                /* ── Rosetta: one program morphing EPL → Python → JavaScript (real transpiler output) ── */
                .ros-shell{max-width:1000px;margin:0 auto}
                .ros-card{position:relative;border:1px solid var(--d-line);border-radius:16px;overflow:hidden;
                    background:var(--d-ink);box-shadow:0 40px 100px -50px rgba(17,17,19,.45)}
                .ros-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;z-index:2;
                    background:linear-gradient(90deg,var(--c1),var(--c2),var(--c3))}
                .ros-head{display:flex;align-items:center;gap:9px;padding:13px 16px;background:var(--d-ink-2);
                    border-bottom:1px solid var(--d-line-soft)}
                .ros-dots{display:flex;gap:7px}
                .ros-dots i{width:11px;height:11px;border-radius:50%;display:block}
                .ros-dots i:nth-child(1){background:#FF5F57}.ros-dots i:nth-child(2){background:#FEBC2E}.ros-dots i:nth-child(3){background:#28C840}
                .ros-file{font-family:'JetBrains Mono',monospace;font-size:11.5px;color:var(--d-paper-faint);letter-spacing:.02em;margin-left:4px}
                .ros-tabs{margin-left:auto;display:inline-flex;background:rgba(255,255,255,.05);
                    border:1px solid var(--d-line);border-radius:9px;padding:3px;gap:2px}
                .ros-tab{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--d-paper-dim);
                    padding:5px 13px;border-radius:6px;cursor:pointer;transition:color .2s,background .2s;white-space:nowrap}
                .ros-tab p{display:inline}
                .ros-tab.on{color:#fff;background:var(--accent)}
                .ros-code{padding:20px 22px;font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.9;
                    min-height:236px;overflow-x:auto;color:var(--d-paper)}
                .ros-row{display:block;white-space:pre;min-height:1.9em}
                .ros-row.morph{animation:ros-in .52s var(--ease) both}
                @keyframes ros-in{from{opacity:0;transform:translateY(7px) scale(.992);filter:blur(1.4px)}
                    to{opacity:1;transform:none;filter:none}}
                .ros-foot{display:flex;flex-wrap:wrap;align-items:center;gap:8px 16px;padding:13px 18px;
                    border-top:1px solid var(--d-line-soft);background:var(--d-ink-2)}
                .ros-run{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--d-paper-dim);white-space:pre-wrap}
                .ros-run b{color:#34D399;font-weight:600}
                .ros-badge{margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;
                    color:var(--d-paper-faint);text-transform:uppercase}
                .ros-badge p{display:inline}
                .ros-fallback{padding:30px 26px;font-size:13px;line-height:1.8;color:var(--d-paper-dim);font-family:'JetBrains Mono',monospace}
                @media(max-width:600px){.ros-code{font-size:12px;padding:16px 16px;min-height:210px}
                    .ros-tab{padding:5px 9px;font-size:11px}.ros-head{gap:7px}.ros-badge{display:none}}

                @media(max-width:820px){.ide-body{grid-template-columns:44px 200px 1fr}}
                /* phone: stack vertically — drop the activity bar, surface the marketplace pane
                   full-width during the install act, hide the non-essential Explorer tree */
                @media(max-width:640px){
                    .ide-body{display:block;min-height:0}
                    .ide-act{display:none}
                    .ide-side{display:block;border-right:0;width:auto}
                    .exp-pane{display:none!important}
                    .ext-pane.show{display:block;border-bottom:1px solid var(--ide-line);padding-bottom:8px}
                    .ide-name{display:none}
                    .skin-toggle{display:inline-flex;margin-left:auto}
                    .skin-opt{padding:4px 9px}
                    .ide-editor{min-height:148px}.ide-term{min-height:140px}
                    .ide-rail{gap:8px}.rail-step{flex:1 1 calc(50% - 4px);max-width:none;padding:12px 13px}}
                @media(max-width:430px){.rail-step{flex-basis:100%}}

                /* ── Embedded live playground ── reuses the dark .code island look */
                .pg-shell{max-width:1000px;margin:0 auto}
                .pg-code{--ink:var(--d-ink);--ink-2:var(--d-ink-2);--paper:var(--d-paper);
                    --paper-dim:var(--d-paper-dim);--paper-faint:var(--d-paper-faint);
                    --line:var(--d-line);--line-soft:var(--d-line-soft)}
                .pg-run{margin-left:auto;display:inline-flex;align-items:center;gap:7px;cursor:pointer;
                    font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;letter-spacing:.02em;
                    color:#fff;padding:7px 16px;border-radius:8px;border:0;
                    background:linear-gradient(135deg,var(--accent),#7C5CFF);
                    box-shadow:0 6px 18px -8px rgba(0,125,243,.7);transition:transform .2s var(--ease),opacity .2s,box-shadow .3s}
                .pg-run::before{content:'\25B6';font-size:9px;transform:translateY(.5px)}
                .pg-run:hover{transform:translateY(-1px);box-shadow:0 10px 24px -8px rgba(0,125,243,.8)}
                .pg-run:active{transform:translateY(0)}
                .pg-run[aria-busy="true"]{pointer-events:none;opacity:.6}
                .pg-run[aria-busy="true"]::before{content:'';width:11px;height:11px;border-radius:50%;
                    border:2px solid rgba(255,255,255,.4);border-top-color:#fff;animation:pg-spin .7s linear infinite}
                @keyframes pg-spin{to{transform:rotate(360deg)}}
                .pg-editor{display:block;width:100%;border:0;outline:0;resize:vertical;tab-size:2;
                    min-height:230px;background:transparent;color:var(--d-paper);
                    padding:24px 26px;font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.65;
                    caret-color:var(--accent)}
                .pg-editor::placeholder{color:var(--d-paper-faint)}
                .pg-out-wrap{border-top:1px solid var(--d-line-soft);background:rgba(0,0,0,.22)}
                .pg-out-head{display:flex;align-items:center;gap:8px;padding:11px 26px;
                    font-family:'JetBrains Mono',monospace;font-size:10.5px;letter-spacing:.18em;
                    text-transform:uppercase;color:var(--d-paper-faint)}
                .pg-out-head .pg-status{margin-left:auto;text-transform:none;letter-spacing:0;font-size:11.5px;color:var(--d-paper-dim)}
                .pg-out{margin:0;padding:6px 26px 24px;min-height:42px;max-height:320px;overflow:auto;
                    font-family:'JetBrains Mono',monospace;font-size:13px;line-height:1.6;
                    color:var(--d-paper);white-space:pre-wrap;word-break:break-word}
                .pg-out.empty{color:var(--d-paper-faint)}
                .pg-out.err{color:#FF9AAB}
                .pg-foot{margin-top:18px;text-align:center;font-size:13px;color:var(--paper-dim)}
                .pg-foot a{color:var(--accent)}
                .pg-foot a:hover{text-decoration:underline}

                /* pillars */
                .pillar{display:grid;grid-template-columns:84px 1fr 170px;gap:34px;align-items:start;
                    padding:44px 24px;border-top:1px solid var(--line);position:relative;border-radius:16px;
                    transition:background .35s}
                .pillar::before{content:'';position:absolute;inset:0;border-radius:16px;pointer-events:none;opacity:0;
                    transition:opacity .35s;background:radial-gradient(440px circle at var(--mx,-200px) var(--my,-200px),var(--accent-soft),transparent 60%)}
                .pillar:hover::before{opacity:1}
                .pillar:hover{background:linear-gradient(90deg, var(--accent-soft), transparent 42%)}
                .pillar:hover .pillar-title{color:var(--accent)}
                .pillar:hover .pillar-idx{opacity:1;transform:translateX(2px)}
                .pillar-idx{font-family:'JetBrains Mono',monospace;font-size:22px;font-weight:700;padding-top:4px;background:linear-gradient(155deg, var(--accent), #7C5CFF);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;opacity:.5;transition:opacity .35s var(--ease),transform .35s var(--ease)}
                .pillar-idx p{display:inline}
                .pillar-title{font-family:var(--display);font-size:clamp(1.55rem,2.7vw,2.1rem);letter-spacing:-.02em;line-height:1.1;
                    transition:color .3s;margin-bottom:15px;font-weight:600}
                .pillar-desc{font-size:var(--fs-body-sm);line-height:var(--lh-body-sm);color:var(--paper-dim);max-width:var(--measure-card)}
                .pillar-meta{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.16em;
                    text-transform:uppercase;color:var(--paper-faint);text-align:right;padding-top:11px}
                .pillar-meta p{display:inline}
                @media(max-width:820px){.pillar{grid-template-columns:50px 1fr;gap:20px;padding:36px 16px}.pillar-meta{display:none}}

                /* audience personas — gradient icon tiles, per-persona accent, pill badges */
                .audience-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:18px;margin-top:8px;perspective:1400px}
                .audience-card{--ac:#2EA0FF;background:linear-gradient(180deg,color-mix(in srgb,var(--ac) 4%,var(--ink-2)),var(--ink-2));border:1px solid var(--line);border-radius:22px;padding:34px 32px 30px;position:relative;overflow:hidden;isolation:isolate;transform-style:preserve-3d;box-shadow:0 1px 2px rgba(17,17,19,.04),0 12px 30px -22px rgba(17,17,19,.22);transition:transform .45s var(--ease),border-color .4s,box-shadow .45s,background .4s}
                .audience-card:nth-child(1){--ac:#2EA0FF}
                .audience-card:nth-child(2){--ac:#7C5CFF}
                .audience-card:nth-child(3){--ac:#FF5C7A}
                .audience-card:nth-child(4){--ac:#21C7A8}
                /* pointer-follow accent bloom */
                .audience-card::before{content:'';position:absolute;inset:0;z-index:-1;pointer-events:none;opacity:0;transition:opacity .4s;background:radial-gradient(460px circle at var(--mx,-200px) var(--my,-200px), color-mix(in srgb, var(--ac) 16%, transparent), transparent 62%)}
                /* top hairline that draws in from center on hover */
                .audience-card::after{content:'';position:absolute;left:0;right:0;top:0;height:2px;z-index:3;opacity:0;transform:scaleX(.3);transition:opacity .45s,transform .55s var(--ease);background:linear-gradient(90deg, transparent, var(--ac), transparent)}
                .audience-card:hover{transform:translateY(-6px);border-color:color-mix(in srgb, var(--ac) 46%, var(--line));box-shadow:0 2px 4px rgba(17,17,19,.05),0 40px 80px -46px color-mix(in srgb,var(--ac) 70%,transparent)}
                .audience-card:hover::before{opacity:1}
                .audience-card:hover::after{opacity:.95;transform:scaleX(1)}
                /* large ghosted persona glyph — editorial corner identity (injected) */
                .audience-glyph{position:absolute;top:-20px;right:-20px;width:138px;height:138px;z-index:0;pointer-events:none;opacity:.05;color:var(--ac);transform:rotate(-8deg);transition:opacity .5s var(--ease),transform .6s var(--ease)}
                .audience-glyph svg{width:100%;height:100%;stroke:currentColor;stroke-width:1;fill:none;stroke-linecap:round;stroke-linejoin:round}
                .audience-card:hover .audience-glyph{opacity:.13;transform:rotate(0deg) scale(1.05)}
                .audience-icon,.audience-title,.audience-desc,.audience-tag{position:relative;z-index:2}
                .audience-icon{width:54px;height:54px;display:flex;align-items:center;justify-content:center;margin-bottom:22px;border-radius:15px;overflow:hidden;border:1px solid color-mix(in srgb, var(--ac) 30%, var(--line));background:linear-gradient(150deg, color-mix(in srgb, var(--ac) 16%, var(--ink-2)), var(--ink-2));box-shadow:inset 0 1px 0 rgba(255,255,255,.7);transition:transform .45s var(--ease),border-color .4s,box-shadow .45s}
                /* sheen sweep across the icon tile on hover */
                .audience-icon::after{content:'';position:absolute;inset:0;z-index:0;background:linear-gradient(120deg,transparent 32%,rgba(255,255,255,.6) 50%,transparent 68%);transform:translateX(-130%);transition:transform .8s var(--ease)}
                .audience-card:hover .audience-icon{transform:translateY(-2px) scale(1.06);border-color:color-mix(in srgb,var(--ac) 55%,var(--line));box-shadow:inset 0 1px 0 rgba(255,255,255,.8),0 14px 28px -14px color-mix(in srgb,var(--ac) 62%,transparent)}
                .audience-card:hover .audience-icon::after{transform:translateX(130%)}
                .audience-icon svg{width:26px;height:26px;display:block;position:relative;z-index:1;color:var(--ac);stroke:currentColor;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round;fill:none}
                /* stroke draw-on when the card scrolls into view */
                .audience-icon svg *{stroke-dasharray:200;stroke-dashoffset:200;transition:stroke-dashoffset .95s var(--ease) .1s}
                .audience-card.in .audience-icon svg *{stroke-dashoffset:0}
                .audience-icon p{display:inline}
                .audience-title{font-family:var(--display);font-size:1.34rem;font-weight:600;letter-spacing:-.02em;margin-bottom:12px;color:var(--paper);display:inline-block}
                .audience-title::after{content:'';display:block;height:2px;margin-top:5px;width:100%;border-radius:2px;background:linear-gradient(90deg,var(--ac),transparent);transform:scaleX(0);transform-origin:left;transition:transform .55s var(--ease)}
                .audience-card:hover .audience-title::after{transform:scaleX(1)}
                .audience-title p{display:inline}
                .audience-desc{font-size:var(--fs-body-sm);line-height:var(--lh-body-sm);color:var(--paper-dim);max-width:var(--measure-card)}
                .audience-desc p{display:inline}
                .audience-tag{display:inline-flex;align-items:center;gap:8px;margin-top:22px;font-family:'JetBrains Mono',monospace;font-size:10.5px;letter-spacing:.13em;text-transform:uppercase;color:var(--ac);background:color-mix(in srgb, var(--ac) 9%, transparent);border:1px solid color-mix(in srgb, var(--ac) 24%, transparent);padding:7px 13px;border-radius:999px;transition:background .4s,border-color .4s,box-shadow .4s}
                .audience-card:hover .audience-tag{background:color-mix(in srgb,var(--ac) 16%,transparent);border-color:color-mix(in srgb,var(--ac) 42%,transparent);box-shadow:0 6px 16px -10px color-mix(in srgb,var(--ac) 70%,transparent)}
                .audience-tag::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--ac);box-shadow:0 0 0 0 var(--ac);transition:box-shadow .4s}
                .audience-card:hover .audience-tag::before{box-shadow:0 0 10px 1px color-mix(in srgb,var(--ac) 80%,transparent)}
                .audience-tag p{display:inline}
                /* keep the personas 2-up on phones (a single column read as an
                   unprofessional stack); only fall to one column on very narrow devices.
                   2-up cards get compact typography so they don't run tall. */
                @media(max-width:760px){
                    .audience-grid{gap:12px}
                    .audience-card{padding:22px 18px 20px}
                    .audience-icon{width:44px;height:44px;margin-bottom:14px}
                    .audience-icon svg{width:22px;height:22px}
                    .audience-title{font-size:1.16rem;margin-bottom:7px}
                    .audience-desc{font-size:.88rem;line-height:1.48}
                    .audience-tag{margin-top:13px;padding:6px 11px;font-size:10px}
                    .audience-glyph{width:104px;height:104px;top:-14px;right:-14px}
                }
                @media(max-width:380px){.audience-grid{grid-template-columns:1fr}}

                /* targets bento grid — per-output accent spectrum, ordinal watermark, terminal caret */
                .targets{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;perspective:1200px;counter-reset:tg}
                .target{--ac:#4F46E5;counter-increment:tg;background:linear-gradient(180deg,color-mix(in srgb,var(--ac) 4%,var(--ink-2)),var(--ink-2));border:1px solid var(--line);border-radius:18px;padding:28px 24px;
                    position:relative;overflow:hidden;transform-style:preserve-3d;isolation:isolate;
                    box-shadow:0 1px 2px rgba(17,17,19,.04),0 10px 26px -20px rgba(17,17,19,.2);
                    transition:transform .25s var(--ease),border-color .4s,box-shadow .45s,background .4s}
                /* one accent per compile target — the section reads as a spectrum of outputs */
                .target:nth-child(1){--ac:#2EA0FF}
                .target:nth-child(2){--ac:#4F46E5}
                .target:nth-child(3){--ac:#7C5CFF}
                .target:nth-child(4){--ac:#0EA5A5}
                .target:nth-child(5){--ac:#F59E0B}
                .target:nth-child(6){--ac:#8B5CF6}
                .target:nth-child(7){--ac:#3B82F6}
                .target:nth-child(8){--ac:#FF5C7A}
                /* pointer-follow accent bloom */
                .target::before{content:'';position:absolute;inset:0;z-index:-1;pointer-events:none;opacity:0;transition:opacity .4s;
                    background:radial-gradient(340px circle at var(--mx,-200px) var(--my,-200px),color-mix(in srgb,var(--ac) 15%,transparent),transparent 62%)}
                /* large ghosted ordinal (01–08) — editorial corner identity, auto-numbered */
                .target::after{content:counter(tg,decimal-leading-zero);position:absolute;top:6px;right:16px;z-index:0;
                    font-family:var(--display);font-weight:700;font-size:56px;line-height:1;letter-spacing:-.03em;
                    color:var(--ac);opacity:.07;pointer-events:none;transition:opacity .5s var(--ease),transform .55s var(--ease)}
                .target:hover{border-color:color-mix(in srgb,var(--ac) 42%,var(--line));box-shadow:0 2px 4px rgba(17,17,19,.05),0 34px 70px -40px color-mix(in srgb,var(--ac) 68%,transparent)}
                .target:hover::before{opacity:1}
                .target:hover::after{opacity:.16;transform:translateY(-2px) scale(1.06)}
                .target-cmd,.target-out,.target-note{position:relative;z-index:1}
                .target-cmd{font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--ac);display:flex;align-items:center;transition:transform .4s var(--ease)}
                /* terminal prompt caret that lights up on hover */
                .target-cmd::before{content:'$';opacity:.4;margin-right:7px;transition:opacity .4s}
                .target:hover .target-cmd{transform:translateX(3px)}
                .target:hover .target-cmd::before{opacity:1}
                .target-cmd p{display:inline}
                .target-out{margin-top:16px;font-size:14.5px;color:var(--paper);font-weight:700;display:inline-block}
                /* accent underline draws under the output label on hover */
                .target-out::after{content:'';display:block;height:2px;margin-top:6px;width:100%;border-radius:2px;background:linear-gradient(90deg,var(--ac),transparent);transform:scaleX(0);transform-origin:left;transition:transform .5s var(--ease)}
                .target:hover .target-out::after{transform:scaleX(1)}
                .target-out p{display:inline}
                .target-note{margin-top:6px;font-size:13px;color:var(--paper-dim)}
                @media(max-width:880px){.targets{grid-template-columns:1fr 1fr}}
                @media(max-width:360px){.targets{grid-template-columns:1fr}}

                /* ── mobile density pass ── the page read "too texty" on phones: large
                   section voids + roomy cards turned every screen into a wall of text.
                   Tighten vertical rhythm, keep the targets grid 2-up (denser bento),
                   trim card padding, and compress body copy a touch so the content
                   breathes as designed instead of sprawling. */
                @media(max-width:600px){
                    :root{--fs-body:1rem;--lh-body:1.6;--fs-body-sm:.95rem;--lh-body-sm:1.58}
                    .section{padding:54px 0}
                    .sec-head{margin-bottom:30px}
                    .pillar{padding:26px 15px;gap:15px}
                    .pillar-title{margin-bottom:9px}
                    .pillar-idx{font-size:19px}
                    .audience-card{padding:20px 15px 18px}
                    .audience-icon{width:40px;height:40px;margin-bottom:12px}
                    .audience-title{font-size:1.1rem;margin-bottom:6px}
                    .audience-desc{font-size:.86rem;line-height:1.46}
                    .audience-tag{margin-top:12px}
                    .target{padding:20px 16px}
                    .target::after{font-size:42px;top:4px;right:12px}
                    .target-cmd{font-size:12px}
                    .target-out{margin-top:10px;font-size:14px}
                    .target-note{font-size:12.5px;line-height:1.5}
                    .split-p{margin-top:18px}
                }

                /* ecosystem marquee */
                .marquee{overflow:hidden;position:relative;
                    -webkit-mask:linear-gradient(90deg,transparent,#000 7%,#000 93%,transparent);
                    mask:linear-gradient(90deg,transparent,#000 7%,#000 93%,transparent)}
                .mq-track{display:flex;gap:14px;width:max-content;animation:scrollx 42s linear infinite;will-change:transform}
                .marquee:hover .mq-track{animation-play-state:paused}
                @keyframes scrollx{to{transform:translateX(-50%)}}
                .pkg{font-family:'JetBrains Mono',monospace;font-size:13.5px;color:var(--paper-dim);white-space:nowrap;
                    border:1px solid var(--line);border-radius:999px;padding:11px 20px;transition:all .25s;background:var(--ink)}
                .pkg p{display:inline}
                .pkg:hover{color:var(--paper);border-color:var(--accent);box-shadow:0 8px 24px -12px var(--accent-soft)}

                /* install */
                .term{background:var(--d-ink);border:1px solid var(--line);border-radius:16px;
                    font-family:'JetBrains Mono',monospace;font-size:14.5px;padding:22px 24px;color:var(--d-paper);
                    display:flex;align-items:center;justify-content:space-between;gap:18px;position:relative;overflow:hidden}
                .term::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;
                    background:linear-gradient(90deg,var(--c1),var(--c2),var(--c3))}
                .term-cmd p{display:inline}
                .term-cmd .sig{color:var(--c3);margin-right:12px}
                .caret{display:inline-block;width:9px;height:1.05em;background:var(--c3);margin-left:6px;
                    vertical-align:-2px;animation:blink 1.1s step-end infinite}
                .caret p{display:none}
                @keyframes blink{50%{opacity:0}}
                .term-copy{font-size:12px;color:var(--d-paper-faint);border:1px solid var(--d-line);
                    border-radius:8px;padding:7px 14px;cursor:pointer;transition:all .2s;user-select:none;white-space:nowrap}
                .term-copy p{display:inline}
                .term-copy:hover{color:var(--d-paper);border-color:var(--d-paper)}

                /* closing cta */
                .cta{text-align:center;padding:clamp(96px,14vw,180px) var(--gut);position:relative;overflow:hidden;isolation:isolate}
                /* dotted grid, faded to the centre (Antigravity finale backdrop) */
                .cta::before{content:'';position:absolute;inset:0;z-index:0;background-image:radial-gradient(rgba(17,17,19,.08) 1.1px, transparent 1.1px);background-size:26px 26px;-webkit-mask-image:radial-gradient(ellipse 72% 64% at 50% 44%, transparent 0%, transparent 30%, black 88%);mask-image:radial-gradient(ellipse 72% 64% at 50% 44%, transparent 0%, transparent 30%, black 88%);pointer-events:none}
                /* soft blue-violet bloom behind the headline */
                .cta::after{content:'';position:absolute;left:50%;top:40%;transform:translate(-50%,-50%);width:min(940px,92%);height:560px;z-index:0;background:radial-gradient(ellipse at center, rgba(46,160,255,.18), rgba(124,92,255,.11) 42%, transparent 72%);filter:blur(18px);pointer-events:none}
                .cta-h{font-family:var(--display);font-size:clamp(2.7rem,7.4vw,6rem);line-height:1.02;letter-spacing:-.035em;font-weight:500;position:relative;z-index:2;margin:0}
                .cta-h .serif,.cta-h .g{color:var(--muted);font-weight:500}
                .cta-sub{margin:26px auto 40px;max-width:var(--measure);font-size:var(--fs-body);color:var(--paper-dim);line-height:var(--lh-body);position:relative;z-index:2}
                .cta-actions{justify-content:center;position:relative;z-index:2}

                /* footer */
                .foot{border-top:1px solid var(--line);padding:78px var(--gut) 0;position:relative;z-index:2;overflow:hidden}
                .foot-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:42px;max-width:1200px;margin:0 auto}
                .foot-mark{font-family:var(--display);font-weight:700;font-size:26px;letter-spacing:-.02em;display:inline-flex;align-items:center;gap:11px}
                .foot-mark::before{content:'';width:30px;height:34px;
                    background:var(--logo) center/contain no-repeat}
                .foot-mark p{display:inline}
                .foot-tag{margin-top:16px;font-size:14px;color:var(--paper-dim);max-width:30ch;line-height:1.55}
                .foot-col h2{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.18em;
                    text-transform:uppercase;color:var(--paper-faint);margin:0 0 20px;font-weight:500}
                .foot-col a{display:block;font-size:14px;color:var(--paper-dim);margin-bottom:13px;transition:color .2s,padding-left .2s}
                .foot-col a:hover{color:var(--paper);padding-left:4px}
                .foot-bar{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;
                    max-width:1200px;margin:56px auto 0;padding-top:28px;border-top:1px solid var(--line-soft);
                    font-size:13px;color:var(--paper-faint)}
                .foot-bar p{display:inline}
                .foot-legal{display:flex;gap:24px;flex-wrap:wrap}
                .foot-legal a{color:var(--paper-faint);transition:color .2s}
                .foot-legal a:hover{color:var(--paper)}
                /* giant full-bleed wordmark (Antigravity footer signature) */
                .foot-giant{margin-top:34px;text-align:center;line-height:.78;font-family:var(--display);font-weight:700;letter-spacing:-.04em;
                    font-size:clamp(5rem,27vw,24rem);color:var(--paper);
                    background:linear-gradient(180deg,var(--paper) 0%,var(--paper) 55%,rgba(17,17,19,.06) 130%);
                    -webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;
                    user-select:none;pointer-events:none}
                @media(max-width:820px){.foot-grid{grid-template-columns:1fr 1fr}}
                @media(max-width:520px){.foot-grid{grid-template-columns:1fr}}

                /* native words pull-up */
                /* keep segments flowing as one paragraph before/without the JS splitter */
                .pull-words p{display:inline}
                .native-pull-up{display:inline-block;opacity:0;transform:translateY(18px);
                    transition:opacity .8s var(--ease),transform .8s var(--ease)}
                .native-pull-up.visible{opacity:1;transform:translateY(0)}

                /* ── accessibility: respect reduced motion ─────────────────── */
                @media (prefers-reduced-motion: reduce){
                    *{animation:none!important;transition-duration:.01ms!important;scroll-behavior:auto!important}
                    .reveal{opacity:1!important;transform:none!important;filter:none!important}
                    .orbital{display:none!important}
                    .hero::before{display:none!important}
                    .hero-scroll{display:none!important}
                    .hero-h .g{background:none!important;color:var(--accent)!important;-webkit-text-fill-color:var(--accent)!important}
                    .mq-track{animation:none!important}
                }
                
        End

        Note: ── Skip link (keyboard / screen-reader landmark) ─────────────
        Div class "skip-link-wrap"
            Link "Skip to content" to "#top"
        End

        Note: ── Scroll progress ──────────────────────────────────────────
        Div class "scroll-progress"
        End

        Note: ── Navigation ───────────────────────────────────────────────
        Nav class "nav" id "nav"
            Div class "nav-brand"
                Link "EPL" to "#top"
            End
            Div class "nav-links"
                Link "Overview" to "#manifesto"
                Link "Syntax" to "#syntax"
                Link "Playground" to "#playground"
                Link "Targets" to "#targets"
                Link "Ecosystem" to "#ecosystem"
            End
            Div class "nav-cta-wrap"
                Link "Install" to "#install"
            End
            Div class "nav-toggle" id "navToggle"
                Span class "nav-toggle-bar"
                End
                Span class "nav-toggle-bar"
                End
                Span class "nav-toggle-bar"
                End
            End
        End

        Note: ── Hero — centered composition over the EPL particle vortex ───
        Header class "hero" id "top"
            Div class "hero-lockup reveal"
                Text "EPL"
            End
            Div class "hero-badge reveal dly-1"
                Span class "ping"
                End
                Text "The English Programming Language"
            End
            Div class "hero-h" id "hero-h"
                Span class "w"
                    Text "Write "
                End
                Span class "w"
                    Text "code "
                End
                Span class "w"
                    Text "the "
                End
                Span class "w"
                    Text "way "
                End
                Span class "w"
                    Text "you "
                End
                Span class "w"
                    Text "think."
                End
            End
            Div class "hero-sub reveal dly-2"
                Text "A genuine programming language — bytecode VM, LLVM-native compilation, eight targets, and 725+ builtins — with a syntax anyone can read on the first try."
            End
            Div class "btn-row mag-group reveal dly-3"
                Link "pip install eplang" to "#install"
                Link "Read the docs" to "https://abneeshsingh21.github.io/EPL/"
            End
            Div class "hero-meta reveal dly-4"
                Span class "m"
                    Text "Apache-2.0"
                End
                Span class "m"
                    Text "Python 3.9–3.13"
                End
                Span class "m"
                    Text "2,100+ tests"
                End
            End
            Div class "hero-scroll"
            End
        End

        Note: ── Stats (count-up) ─────────────────────────────────────────
        Section class "stats"
            Div class "stat reveal"
                Div class "stat-num count"
                    Text "725+"
                End
                Div class "stat-label"
                    Text "built-in functions across the standard library"
                End
            End
            Div class "stat reveal dly-1"
                Div class "stat-num count"
                    Text "8"
                End
                Div class "stat-label"
                    Text "compilation targets from one source file"
                End
            End
            Div class "stat reveal dly-2"
                Div class "stat-num count"
                    Text "22"
                End
                Div class "stat-label"
                    Text "official packages in the registry"
                End
            End
            Div class "stat reveal dly-3"
                Div class "stat-num count"
                    Text "2,100+"
                End
                Div class "stat-label"
                    Text "tests gating every release in CI"
                End
            End
        End

        Note: ── Interactive IDE walkthrough — install ▸ write ▸ run, real EPL ──
        Section class "section" id "demo"
            Div class "wrap"
                Div class "sec-head"
                    Div class "eyebrow reveal"
                        Text "From zero to running"
                    End
                    Div class "sec-h reveal dly-1"
                        Text "Set up EPL in your editor, "
                        Span class "g"
                            Text "in under a minute."
                        End
                    End
                    Div class "split-p reveal dly-2"
                        Text "A guided walkthrough in a real editor: install the EPL extension, install the language, write plain-English code, and run it. Works in VS Code and Antigravity IDE — flip the skin in the title bar."
                    End
                End
                Div class "ide-shell glow reveal dly-2"
                    Div class "ide vscode" id "epl-ide"
                        Note: JS builds the full IDE chrome here; static fallback below for no-JS
                        Div id "ide-mount"
                            Div class "ide-fallback"
                                Text "1 · Install the extension “EPL — English Programming Language” (epl-lang.epl-lang) from the VS Code Marketplace or Open VSX. 2 · Install the language: pip install eplang. 3 · Write hello.epl. 4 · Run it: epl run hello.epl"
                            End
                        End
                    End
                    Div class "ide-rail" id "ide-rail"
                    End
                    Div class "ide-foot reveal dly-3"
                        Text "Every command and line of EPL above is real. "
                        Link "Try it yourself in the live playground" to "#playground"
                    End
                End
            End
        End

        Note: ── Manifesto ────────────────────────────────────────────────
        Section class "section" id "manifesto"
            Div class "wrap manifesto"
                Div class "eyebrow reveal"
                    Text "The premise"
                End
                Div class "lead reveal dly-1 pull-words" id "scroll-text"
                    Text "EPL closes the gap between pseudocode and software. "
                    Span class "italic-serif"
                        Text "What you mean is what you run — "
                    End
                    Text "no semicolons, no curly braces, no cryptic symbols, and none of the ceremony that keeps people out of programming."
                End
            End
        End

        Note: ── Rosetta — one program morphing across languages (real transpiler output) ──
        Section class "section" id "rosetta"
            Div class "wrap"
                Div class "sec-head"
                    Div class "eyebrow reveal"
                        Text "One program, every language"
                    End
                    Div class "sec-h reveal dly-1"
                        Text "You write the English. "
                        Span class "g"
                            Text "EPL writes the rest."
                        End
                    End
                    Div class "split-p reveal dly-2"
                        Text "The very same program — transpiled to Python, JavaScript and six more targets by the compiler you install. Watch it morph, line for line. Every snippet is real compiler output."
                    End
                End
                Div class "ros-shell glow reveal dly-2"
                    Div class "ros-card" id "ros-card"
                        Div id "ros-mount"
                            Div class "ros-fallback"
                                Text "The same six lines, transpiled by EPL to Python, JavaScript and six more targets — identical output in every one."
                            End
                        End
                    End
                End
            End
        End

        Note: ── Syntax / code split ──────────────────────────────────────
        Section class "section" id "syntax"
            Div class "wrap split"
                Div class "split-left"
                    Div class "eyebrow reveal"
                        Text "Readable by design"
                    End
                    Div class "sec-h reveal dly-1"
                        Text "A REST API "
                        Span class "g"
                            Text "you can read aloud."
                        End
                    End
                    Div class "split-p reveal dly-2"
                        Text "The same program runs on the tree-walking interpreter, the bytecode VM, or compiles to a native binary. The syntax never changes."
                    End
                    Div class "split-list reveal dly-3"
                        Div class "li"
                            Text "Routing, sessions, and JSON are part of the language — not a framework you bolt on."
                        End
                        Div class "li"
                            Text "Gradual static typing with epl check, plus a formatter and linter in the box."
                        End
                    End
                End
                Div class "split-right glow reveal dly-2"
                    Div class "code"
                        Div class "code-bar"
                            Span class "dot"
                            End
                            Span class "dot"
                            End
                            Span class "dot"
                            End
                            Span class "code-file"
