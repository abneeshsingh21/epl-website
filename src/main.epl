        Note: ── Motion system (progressive enhancement only) ─────────────
        Script
            (function () {
                var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

                // ── Audience icons: professional inline line-icons (replace emoji) ──
                (function setAudienceIcons() {
                    var P = 'http://www.w3.org/2000/svg';
                    function svg(paths) {
                        var s = '<svg xmlns="' + P + '" viewBox="0 0 24 24" aria-hidden="true">' + paths + '</svg>';
                        return s;
                    }
                    var ICONS = {
                        // graduation cap — students & beginners
                        'ico-students': svg('<path d="M2 8.5 12 4l10 4.5-10 4.5L2 8.5Z"/><path d="M6 10.5V15c0 1.5 2.7 3 6 3s6-1.5 6-3v-4.5"/><path d="M22 8.5V14"/>'),
                        // presentation board — educators & institutions
                        'ico-educators': svg('<rect x="3" y="4" width="18" height="12" rx="1.5"/><path d="M12 16v4"/><path d="M8 20h8"/><path d="M7.5 11.5 10 9l2 2 3-3.5"/>'),
                        // terminal/tools — professional developers
                        'ico-developers': svg('<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 9l3 3-3 3"/><path d="M13 15h4"/>'),
                        // chip/AI — AI & automation
                        'ico-ai': svg('<rect x="6.5" y="6.5" width="11" height="11" rx="2"/><path d="M9.5 9.5h5v5h-5z"/><path d="M9 3v2M15 3v2M9 19v2M15 19v2M3 9h2M3 15h2M19 9h2M19 15h2"/>')
                    };
                    Object.keys(ICONS).forEach(function (id) {
                        var el = document.getElementById(id);
                        if (!el) return;
                        el.innerHTML = ICONS[id];
                        // clone the same glyph as a large, faint editorial corner watermark
                        var card = el.closest('.audience-card');
                        if (card && !card.querySelector('.audience-glyph')) {
                            var g = document.createElement('div');
                            g.className = 'audience-glyph';
                            g.setAttribute('aria-hidden', 'true');
                            g.innerHTML = ICONS[id];
                            card.appendChild(g);
                        }
                    });
                })();

                // ── Hidey glass nav (Antigravity-style): glass on scroll, hide down / show up ──
                var nav = document.getElementById('nav');
                var prog = document.querySelector('.scroll-progress');
                var lastY = 0, ticking = false;
                function onScroll() {
                    var sc = window.scrollY || document.documentElement.scrollTop;
                    if (nav) {
                        nav.classList.toggle('scrolled', sc > 36);
                        var hide = sc > 140 && sc > lastY + 4;
                        var show = sc < lastY - 4 || sc < 140;
                        if (hide && !nav.classList.contains('open')) nav.classList.add('hidden');
                        else if (show) nav.classList.remove('hidden');
                    }
                    if (prog) {
                        var h = document.documentElement.scrollHeight - window.innerHeight;
                        prog.style.transform = 'scaleX(' + (h > 0 ? sc / h : 0) + ')';
                    }
                    lastY = sc < 0 ? 0 : sc;
                    if (typeof parallaxGlows === 'function') parallaxGlows();
                    ticking = false;
                }
                window.addEventListener('scroll', function () {
                    if (!ticking) { requestAnimationFrame(onScroll); ticking = true; }
                }, { passive: true });
                onScroll();

                // ── Mobile nav: hamburger toggles the slide-in menu ──
                var navToggle = document.getElementById('navToggle');
                if (navToggle && nav) {
                    navToggle.setAttribute('role', 'button');
                    navToggle.setAttribute('tabindex', '0');
                    navToggle.setAttribute('aria-label', 'Toggle navigation menu');
                    function toggleMenu() { nav.classList.toggle('open'); }
                    navToggle.addEventListener('click', toggleMenu);
                    navToggle.addEventListener('keydown', function (e) {
                        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleMenu(); }
                    });
                    nav.querySelectorAll('.nav-links a, .nav-cta-wrap a').forEach(function (a) {
                        a.addEventListener('click', function () { nav.classList.remove('open'); });
                    });
                }

                function countUp(el) {
                    var raw = el.getAttribute('data-raw') || el.textContent.trim();
                    el.setAttribute('data-raw', raw);
                    var m = raw.match(/[\d,]+/);
                    if (!m) return;
                    var target = parseInt(m[0].replace(/,/g, ''), 10);
                    var prefix = raw.slice(0, m.index), suffix = raw.slice(m.index + m[0].length);
                    if (reduce) { el.textContent = prefix + target.toLocaleString() + suffix; return; }
                    var dur = 1500, t0 = null;
                    function tick(t) {
                        if (!t0) t0 = t;
                        var p = Math.min((t - t0) / dur, 1);
                        var e = 1 - Math.pow(1 - p, 3);
                        el.textContent = prefix + Math.floor(e * target).toLocaleString() + suffix;
                        if (p < 1) requestAnimationFrame(tick);
                    }
                    requestAnimationFrame(tick);
                }

                // ── varied entrance choreography ── give each element a distinct
                // motion by role instead of the uniform fade-up, so scrolling reads
                // as designed rhythm rather than one repeated animation. Explicit
                // r-* classes in markup win; otherwise assign by what the element is.
                function assignVariant(el) {
                    if (/\br-(left|right|scale|zoom|rise)\b/.test(el.className)) return;
                    var c = el.classList, v;
                    if (c.contains('sec-h') || c.contains('cta-h')) v = 'r-zoom';
                    else if (c.contains('stat')) v = 'r-rise';
                    else if (c.contains('pillar') || c.contains('target') || c.contains('audience-card')) v = 'r-scale';
                    else if (c.contains('ide-shell') || c.contains('ros-shell') || c.contains('pg-shell') || c.contains('split-right')) v = 'r-right';
                    else if (c.contains('split-list') || c.contains('lead')) v = 'r-left';
                    if (v) el.classList.add(v);
                }

                var io = new IntersectionObserver(function (entries) {
                    entries.forEach(function (en) {
                        if (en.isIntersecting) {
                            en.target.classList.add('in');
                            if (en.target.classList.contains('count')) countUp(en.target);
                            io.unobserve(en.target);
                        }
                    });
                }, { threshold: 0.16, rootMargin: '0px 0px -40px 0px' });
                document.querySelectorAll('.reveal, .count').forEach(function (el) { assignVariant(el); io.observe(el); });

                // ── continuous glow parallax ── the aurora auras drift vertically as
                // the card travels through the viewport, adding depth behind the
                // product cards instead of sitting static. Cheap: a handful of nodes,
                // rect read on the already-throttled scroll frame.
                var glowEls = reduce ? [] : Array.prototype.slice.call(document.querySelectorAll('.glow'));
                function parallaxGlows() {
                    if (!glowEls || !glowEls.length) return;
                    var vh = window.innerHeight || 1;
                    for (var i = 0; i < glowEls.length; i++) {
                        var el = glowEls[i], r = el.getBoundingClientRect();
                        // -1 (card entering from bottom) → 1 (leaving at top)
                        var mid = (r.top + r.height / 2) / vh;
                        var gy = (0.5 - mid) * 60; // px; aura leans opposite the scroll travel
                        el.style.setProperty('--gy', gy.toFixed(1) + 'px');
                    }
                }
                parallaxGlows();
                window.addEventListener('resize', parallaxGlows, { passive: true });

                // ── word-level pull-up: split .pull-words into per-word spans ──
                // Reproduces the old WordsPullUpMultiStyle output in the motion layer.
                // Source stays semantic (plain text + styled spans), so if this JS never
                // runs the copy is still fully visible — no opacity:0 trap.
                Array.prototype.forEach.call(document.querySelectorAll('.pull-words'), function (host) {
                    var wrap = document.createElement('span');
                    wrap.className = 'native-words-wrapper';
                    var n = 0;
                    function emit(text, cls) {
                        text.split(/\s+/).forEach(function (w) {
                            if (!w) return;
                            if (n > 0) wrap.appendChild(document.createTextNode(' '));
                            var s = document.createElement('span');
                            s.className = 'native-pull-up' + (cls ? ' ' + cls : '');
                            s.style.transitionDelay = (n * 0.1) + 's';
                            if (reduce) s.classList.add('visible');
                            s.textContent = w;
                            wrap.appendChild(s);
                            n++;
                        });
                    }
                    Array.prototype.forEach.call(host.childNodes, function (node) {
                        if (node.nodeType === 3) emit(node.textContent, '');
                        else if (node.nodeType === 1) emit(node.textContent, node.className);
                    });
                    host.textContent = '';
                    host.appendChild(wrap);
                });

                var wio = new IntersectionObserver(function (entries) {
                    entries.forEach(function (en) { if (en.isIntersecting) en.target.classList.add('visible'); });
                }, { threshold: 0.1 });
                document.querySelectorAll('.native-pull-up').forEach(function (el) { wio.observe(el); });

                // ── Interactive IDE walkthrough ── install ▸ write ▸ run ──
                // A scripted onboarding journey in a faux IDE: install the real
                // EPL extension (epl-lang.epl-lang — verified on the VS Code
                // Marketplace & Open VSX), install the language (pip install
                // eplang), write plain-English EPL, and run it. The editor code
                // and program output are the verified Basics example (epl run).
                // Skin flips between VS Code and Antigravity IDE. Degrades to a
                // fully-rendered final state under prefers-reduced-motion.
                (function ideWalkthrough() {
                    var root = document.getElementById('epl-ide');
                    var mount = document.getElementById('ide-mount');
                    var railEl = document.getElementById('ide-rail');
                    if (!root || !mount || !railEl) return;

                    var PROG = 'Create greeting = "Hello, EPL"\n' +
                               'Say greeting\n' +
                               'Say "Squares from 1 to 5:"\n' +
                               'For i from 1 to 5\n' +
                               '    Say i * i\n' +
                               'End';
                    var RUN_OUT = ['Hello, EPL', 'Squares from 1 to 5:', '1', '4', '9', '16', '25'];
                    var PIP_OUT = [
                        '<span class="term-dim">Collecting eplang</span>',
                        '<span class="term-dim">  Downloading eplang-10.1.0-py3-none-any.whl (1.2 MB)</span>',
                        '<span class="term-dim">Installing collected packages: eplang</span>',
                        '<span class="term-ok">Successfully installed eplang-10.1.0</span>'
                    ];
                    var PROMPT = '<span class="term-prompt">PS C:\\Users\\lenovo\\Desktop\\epl code demo&gt;</span> ';

                    var KW = ('Create Set Say Print For from to End Class Function Return new ' +
                              'If Else While takes yes no true false in each and or not').split(' ');
                    var KWSET = {}; KW.forEach(function (k) { KWSET[k] = 1; });
                    function esc(s) { return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
                    function hl(line) {
                        var out = '', re = /("(?:[^"\\]|\\.)*")|(\b\d+(?:\.\d+)?\b)|([A-Za-z_]\w*)|(\s+)|([^\sA-Za-z0-9"]+)/g, m;
                        while ((m = re.exec(line))) {
                            if (m[1]) out += '<span class="c-str">' + esc(m[1]) + '</span>';
                            else if (m[2]) out += '<span class="c-num">' + esc(m[2]) + '</span>';
                            else if (m[3]) {
                                var w = m[3], next = line.charAt(re.lastIndex);
                                if (KWSET[w]) out += '<span class="c-kw">' + w + '</span>';
                                else if (next === '(') out += '<span class="c-fn">' + w + '</span>';
                                else out += '<span class="c-id">' + w + '</span>';
                            } else if (m[4]) out += m[4];
                            else if (m[5]) out += '<span class="c-dim">' + esc(m[5]) + '</span>';
                        }
                        return out;
                    }

                    // ── SVG glyphs ──
                    var I_EXPLORER = '<svg viewBox="0 0 24 24"><path d="M13 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M13 3v5h5"/></svg>';
                    var I_SEARCH = '<svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>';
                    var I_SCM = '<svg viewBox="0 0 24 24"><circle cx="6" cy="6" r="2.5"/><circle cx="6" cy="18" r="2.5"/><circle cx="18" cy="7" r="2.5"/><path d="M6 8.5v7M18 9.5c0 4.2-7 1-7 5.5"/></svg>';
                    var I_RUN = '<svg viewBox="0 0 24 24"><path d="M7 4l12 8-12 8z"/></svg>';
                    var I_EXT = '<svg viewBox="0 0 24 24"><rect x="3.5" y="3.5" width="7" height="7" rx="1"/><rect x="13.5" y="3.5" width="7" height="7" rx="1"/><rect x="3.5" y="13.5" width="7" height="7" rx="1"/><rect x="13.5" y="13.5" width="7" height="7" rx="1"/></svg>';
                    var I_CHEVD = '<svg viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>';
                    var I_FOLDER = '<svg viewBox="0 0 24 24"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>';
                    var I_VS = '<svg viewBox="0 0 24 24" fill="#007ACC" stroke="none"><path d="M18.4 2.4l3.1 1.5v16.2l-3.1 1.5-8.3-7-4.2 3.2L3 16.6 6.4 12 3 7.4l2.9-1.2 4.2 3.2zM18 7.3L12.5 12 18 16.7z"/></svg>';
                    var I_AG = '<svg viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 3.4l8 17.2h-3.5L12 10l-4.5 10.6H4z"/></svg>';

                    var EXT_DECOYS = [
                        { name: 'EPLCode', desc: 'Provides syntax coloring for the EPL language.', pub: 'Mike Redko' },
                        { name: 'EPLang Syntax', desc: 'Visual Studio Code extension providing EPL grammar.', pub: 'Aram Petrosyan' }
                    ];
                    function decoyCard(d) {
                        return '<div class="ext-card">' +
                            '<span class="ext-logo"><b>FZ</b><i>EPL</i></span>' +
                            '<div class="ext-meta"><div class="ext-tt"><p>' + d.name + '</p></div>' +
                            '<div class="ext-desc"><p>' + d.desc + '</p></div>' +
                            '<div class="ext-row"><span class="ext-pub"><p>' + d.pub + '</p></span>' +
                            '<button class="ext-install" type="button" tabindex="-1"><p>Install</p></button></div></div></div>';
                    }

                    // ── Build the IDE chrome ──
                    mount.innerHTML =
                      '<div class="ide-title">' +
                        '<div class="ide-dots"><i></i><i></i><i></i></div>' +
                        '<div class="ide-name"><span class="ide-mark ide-vsmark">' + I_VS + '</span>' +
                          '<span class="ide-mark ide-agmark">' + I_AG + '</span>' +
                          '<p>hello.epl — <span id="ide-idname">Visual Studio Code</span></p></div>' +
                        '<div class="skin-toggle" id="skin-toggle" role="tablist" aria-label="Editor skin">' +
                          '<span class="skin-opt" data-skin="vscode" role="tab" tabindex="0"><p>VS Code</p></span>' +
                          '<span class="skin-opt" data-skin="antigravity" role="tab" tabindex="0"><p>Antigravity</p></span>' +
                        '</div>' +
                      '</div>' +
                      '<div class="ide-body">' +
                        '<div class="ide-act">' +
                          '<div class="ide-ai" data-ai="explorer">' + I_EXPLORER + '</div>' +
                          '<div class="ide-ai" data-ai="search">' + I_SEARCH + '</div>' +
                          '<div class="ide-ai" data-ai="scm">' + I_SCM + '</div>' +
                          '<div class="ide-ai" data-ai="run">' + I_RUN + '</div>' +
                          '<div class="ide-ai" data-ai="ext">' + I_EXT + '<span class="ai-badge" id="ext-badge" style="display:none">1</span></div>' +
                        '</div>' +
                        '<div class="ide-side">' +
                          '<div class="side-pane ext-pane">' +
                            '<div class="side-head"><p>Extensions: Marketplace</p></div>' +
                            '<div class="ext-search">' + I_SEARCH + '<span class="ext-q" id="ext-q"></span></div>' +
                            '<div class="ext-note" id="ext-note"><p>On the <b>VS Code Marketplace</b> · also on <b>Open VSX</b></p></div>' +
                            '<div class="ext-card sel"><span class="ext-logo"><b>FZ</b><i>EPL</i></span>' +
                              '<div class="ext-meta"><div class="ext-tt"><p>EPL — English Programming Language</p></div>' +
                              '<div class="ext-desc"><p>Embedded HTML/CSS/JS &amp; SQL highlighting, semantic tokens, real-time diagnostics, run/check commands.</p></div>' +
                              '<div class="ext-row"><span class="ext-pub"><p>abneesh singh</p></span>' +
                              '<span class="ext-stars">★★★★★</span>' +
                              '<button class="ext-install" id="ext-install" type="button"><p>Install</p></button></div></div></div>' +
                            decoyCard(EXT_DECOYS[0]) + decoyCard(EXT_DECOYS[1]) +
                          '</div>' +
                          '<div class="side-pane exp-pane">' +
                            '<div class="side-head"><p>Explorer</p></div>' +
                            '<div class="exp-row">' + I_CHEVD + '<p>EPL CODE DEMO</p></div>' +
                            '<div class="exp-row ind">' + I_CHEVD + '<p>code check</p></div>' +
                            '<div class="exp-row ind2 file active"><span class="fz"></span><p>hello.epl</p></div>' +
                            '<div class="exp-row ind">' + I_FOLDER + '<p>EPL</p></div>' +
                          '</div>' +
                        '</div>' +
                        '<div class="ide-main">' +
                          '<div class="ide-tabs"><div class="ide-tab active"><span class="fz"></span><p>hello.epl</p></div></div>' +
                          '<div class="ide-editor"><div class="ide-gutter" id="ide-gutter"><span>1</span></div>' +
                            '<div class="ide-code" id="ide-code"></div></div>' +
                          '<div class="ide-term">' +
                            '<div class="term-tabs"><span>Problems</span><span>Output</span><span>Debug Console</span>' +
                              '<span class="on">Terminal</span><span>Ports</span></div>' +
                            '<div class="term-body" id="term-body"></div>' +
                          '</div>' +
                        '</div>' +
                      '</div>';

                    var extAi = root.querySelector('[data-ai="ext"]');
                    var explAi = root.querySelector('[data-ai="explorer"]');
                    var extBadge = document.getElementById('ext-badge');
                    var extPane = root.querySelector('.ext-pane');
                    var expPane = root.querySelector('.exp-pane');
                    var extQ = document.getElementById('ext-q');
                    var extInstall = document.getElementById('ext-install');
                    var extNote = document.getElementById('ext-note');
                    var idName = document.getElementById('ide-idname');
                    var codeEl = document.getElementById('ide-code');
                    var gutterEl = document.getElementById('ide-gutter');
                    var termBody = document.getElementById('term-body');

                    // ── render helpers ──
                    function setGutter(n) { var g = ''; for (var k = 1; k <= n; k++) g += '<span>' + k + '</span>'; gutterEl.innerHTML = g; }
                    function renderEditor(n, done) {
                        var lines = PROG.split('\n'); var shown = 0, html = '', lc = 0, ln, take;
                        for (var i = 0; i < lines.length; i++) {
                            ln = lines[i]; lc++;
                            if (shown + ln.length < n) { html += '<span class="cline">' + (hl(ln) || '&nbsp;') + '</span>'; shown += ln.length + 1; }
                            else { take = ln.slice(0, Math.max(0, n - shown)); html += '<span class="cline">' + (hl(take) || '') + (done ? '' : '<span class="demo-caret"></span>') + '</span>'; break; }
                        }
                        codeEl.innerHTML = html; setGutter(lc);
                    }
                    function editorGhost() { codeEl.innerHTML = '<span class="cline ide-ghost">Use Ctrl + I to generate code</span>'; setGutter(1); }

                    var termBase = [];
                    function termRender(cur) {
                        var arr = termBase.slice(); if (cur != null) arr.push(cur);
                        termBody.innerHTML = arr.map(function (l) { return '<div class="term-line">' + l + '</div>'; }).join('');
                        termBody.scrollTop = termBody.scrollHeight;
                    }
                    function termIdle() { termRender(PROMPT + '<span class="term-caret"></span>'); }
                    function buildTerm(pip, run) {
                        termBase = [];
                        if (pip) { termBase.push(PROMPT + '<span class="term-cmd">pip install eplang</span>'); PIP_OUT.forEach(function (l) { termBase.push(l); }); }
                        if (run) { termBase.push(PROMPT + '<span class="term-cmd">epl run hello.epl</span>'); RUN_OUT.forEach(function (l) { termBase.push('<span>' + esc(l) + '</span>'); }); }
                        termIdle();
                    }

                    function activity(mode) {
                        extAi.classList.toggle('pulse', mode === 'ext-pulse');
                        explAi.classList.toggle('on', mode === 'explorer');
                        extBadge.style.display = (mode === 'ext-pulse') ? 'none' : 'flex';
                    }
                    function sidePane(name) {
                        extPane.classList.toggle('show', name === 'ext');
                        expPane.classList.toggle('show', name === 'explorer');
                    }
                    function extReset() { extInstall.className = 'ext-install'; extInstall.innerHTML = '<p>Install</p>'; }
                    function extInstalled() { extInstall.className = 'ext-install done'; extInstall.innerHTML = '<p>✓ Installed</p>'; }

                    // ── cumulative base state at the START of act i ──
                    function baseFor(i) {
                        if (i === 0) { activity('ext-pulse'); sidePane('ext'); extQ.innerHTML = ''; extReset(); editorGhost(); buildTerm(false, false); }
                        else if (i === 1) { activity('explorer'); sidePane('explorer'); extQ.innerHTML = 'epl'; extInstalled(); editorGhost(); buildTerm(false, false); }
                        else if (i === 2) { activity('explorer'); sidePane('explorer'); extQ.innerHTML = 'epl'; extInstalled(); editorGhost(); buildTerm(true, false); }
                        else { activity('explorer'); sidePane('explorer'); extQ.innerHTML = 'epl'; extInstalled(); renderEditor(PROG.length, true); buildTerm(true, false); }
                    }
                    function fullStatic() {
                        activity('explorer'); sidePane('explorer'); extQ.innerHTML = 'epl'; extInstalled();
                        renderEditor(PROG.length, true); buildTerm(true, true);
                    }

                    // ── timeline player (pause/resume aware) ──
                    function Timeline(ev, onDone) { this.ev = ev; this.i = 0; this.tp = 0; this.onDone = onDone; this.timer = null; this.dead = false; this.due = 0; this.rem = null; }
                    Timeline.prototype._sched = function (ms) {
                        var self = this, e = self.ev[self.i]; self.due = Date.now() + ms;
                        self.timer = setTimeout(function () { self.timer = null; if (self.dead) return; self.tp = e.t; self.i++; e.fn(); self.next(); }, ms);
                    };
                    Timeline.prototype.next = function () {
                        if (this.dead) return;
                        if (this.i >= this.ev.length) { if (this.onDone) this.onDone(); return; }
                        this._sched(Math.max(0, this.ev[this.i].t - this.tp));
                    };
                    Timeline.prototype.start = function () { this.next(); };
                    Timeline.prototype.pause = function () { if (this.timer) { clearTimeout(this.timer); this.timer = null; this.rem = Math.max(0, this.due - Date.now()); } };
                    Timeline.prototype.resume = function () { if (this.dead || this.timer || this.i >= this.ev.length) return; this._sched(this.rem != null ? this.rem : 0); };
                    Timeline.prototype.cancel = function () { this.dead = true; if (this.timer) { clearTimeout(this.timer); this.timer = null; } };

                    function pushType(ev, t, full, per, render) {
                        for (var n = 0; n <= full.length; n++) { (function (n) { ev.push({ t: t + n * per, fn: function () { render(full.slice(0, n)); } }); })(n); }
                        return t + full.length * per;
                    }
                    function pushCode(ev, t) {
                        for (var n = 1; n <= PROG.length; n++) {
                            (function (n) { ev.push({ t: t, fn: function () { renderEditor(n, false); } }); })(n);
                            var ch = PROG.charAt(n - 1); t += ch === '\n' ? 70 : (ch === ' ' ? 12 : 22);
                        }
                        ev.push({ t: t + 180, fn: function () { renderEditor(PROG.length, true); } });
                        return t + 240;
                    }

                    // ── act builders ── fill ev with absolute-time events ──
                    var BUILD = [
                        function (ev) { // 0 · install extension
                            var t = pushType(ev, 350, 'epl', 95, function (s) { extQ.innerHTML = esc(s); });
                            t += 520;
                            ev.push({ t: t, fn: function () { extInstall.classList.add('press'); } });
                            ev.push({ t: t + 150, fn: function () { extInstall.classList.remove('press'); extInstall.innerHTML = '<p>Installing…</p>'; } });
                            t += 1150;
                            ev.push({ t: t, fn: function () { extInstalled(); extBadge.style.display = 'flex'; } });
                        },
                        function (ev) { // 1 · install the language
                            var cmd = 'pip install eplang';
                            var t = pushType(ev, 300, cmd, 52, function (s) { termRender(PROMPT + '<span class="term-cmd">' + esc(s) + '</span><span class="term-caret"></span>'); });
                            t += 280;
                            ev.push({ t: t, fn: function () { termBase.push(PROMPT + '<span class="term-cmd">' + esc(cmd) + '</span>'); termRender(null); } });
                            PIP_OUT.forEach(function (l, k) { t += (k === PIP_OUT.length - 1 ? 540 : 360); ev.push({ t: t, fn: function () { termBase.push(l); termRender(null); } }); });
                            t += 240; ev.push({ t: t, fn: function () { termIdle(); } });
                        },
                        function (ev) { // 2 · write code
                            pushCode(ev, 320);
                        },
                        function (ev) { // 3 · run it
                            var cmd = 'epl run hello.epl';
                            var t = pushType(ev, 300, cmd, 52, function (s) { termRender(PROMPT + '<span class="term-cmd">' + esc(s) + '</span><span class="term-caret"></span>'); });
                            t += 280;
                            ev.push({ t: t, fn: function () { termBase.push(PROMPT + '<span class="term-cmd">' + esc(cmd) + '</span>'); termRender(null); } });
                            RUN_OUT.forEach(function (l, k) { t += (k === 0 ? 360 : 230); ev.push({ t: t, fn: function () { termBase.push('<span>' + esc(l) + '</span>'); termRender(null); } }); });
                            t += 240; ev.push({ t: t, fn: function () { termIdle(); } });
                        }
                    ];

                    // ── step rail ──
                    var STEPS = [
                        { t: 'Install the extension', d: 'Search <code>epl</code> in Extensions → Install. On VS Code Marketplace &amp; Open VSX.' },
                        { t: 'Install the language', d: 'In the terminal: <code>pip install eplang</code>.' },
                        { t: 'Write plain-English code', d: 'Open <code>hello.epl</code> and say what you mean.' },
                        { t: 'Run it', d: 'Ship output with <code>epl run hello.epl</code>.' }
                    ];
                    var railSteps = [];
                    STEPS.forEach(function (s, i) {
                        var b = document.createElement('button');
                        b.className = 'rail-step'; b.type = 'button'; b.setAttribute('data-step', i);
                        b.innerHTML = '<span class="rail-n">' + (i + 1) + '</span><div class="rail-t"><p>' + s.t + '</p></div><div class="rail-d"><p>' + s.d + '</p></div>';
                        b.addEventListener('click', function () { play(i); });
                        railEl.appendChild(b); railSteps.push(b);
                    });
                    function setRail(active) {
                        railSteps.forEach(function (b, i) {
                            b.classList.toggle('active', i === active);
                            b.classList.toggle('done', i < active);
                        });
                    }

                    // ── controller ──
                    var tl = null, gap = null, started = false, cur = 0, inView = false;
                    function clearGap() { if (gap) { clearTimeout(gap); gap = null; } }
                    function cancelTL() { if (tl) { tl.cancel(); tl = null; } clearGap(); }
                    function play(i) {
                        cancelTL(); cur = i; setRail(i); baseFor(i);
                        var ev = []; BUILD[i](ev);
                        tl = new Timeline(ev, function () {
                            setRail(i); railSteps[i].classList.add('done');
                            gap = setTimeout(function () { play((i + 1) % BUILD.length); }, 1900);
                        });
                        tl.start();
                    }

                    // ── skin toggle ──
                    function setSkin(name) {
                        var ag = name === 'antigravity';
                        root.classList.toggle('antigravity', ag);
                        root.classList.toggle('vscode', !ag);
                        idName.textContent = ag ? 'Antigravity IDE' : 'Visual Studio Code';
                        extNote.innerHTML = ag
                            ? '<p>On <b>Open VSX</b> — used by Antigravity IDE · also on the <b>VS Code Marketplace</b></p>'
                            : '<p>On the <b>VS Code Marketplace</b> · also on <b>Open VSX</b></p>';
                    }
                    root.querySelectorAll('.skin-opt').forEach(function (o) {
                        var pick = function () { setSkin(o.getAttribute('data-skin')); };
                        o.addEventListener('click', pick);
                        o.addEventListener('keydown', function (e) { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); pick(); } });
                    });

                    // ── reduced motion: render the finished state, no animation ──
                    if (reduce) {
                        fullStatic(); setRail(3); railSteps.forEach(function (b) { b.classList.add('done'); });
                        railSteps.forEach(function (b, i) { b.addEventListener('click', function () { /* no-op under reduced motion */ }); });
                        return;
                    }

                    baseFor(0); setRail(0); // inviting "ready to install" teaser before scroll

                    function onView(es) {
                        es.forEach(function (e) {
                            inView = e.isIntersecting;
                            if (e.isIntersecting) { if (!started) { started = true; play(0); } else if (tl) { tl.resume(); } }
                            else if (tl) { tl.pause(); }
                        });
                    }
                    new IntersectionObserver(onView, { threshold: 0.3 }).observe(root);
                    document.addEventListener('visibilitychange', function () {
                        if (!started || !tl) return;
                        if (document.hidden) tl.pause(); else if (inView) tl.resume();
                    });
                })();

                // ── Rosetta: the same program morphing EPL → Python → JavaScript ──
                // Every snippet below is REAL transpiler output (epl python / epl js),
                // shown line-for-line. Auto-cycles in view; click a tab to steer. No
                // animation under prefers-reduced-motion.
                (function rosetta() {
                    var card = document.getElementById('ros-card');
                    var mount = document.getElementById('ros-mount');
                    if (!card || !mount) return;

                    var LANGS = [
                        { key: 'EPL', file: 'hello.epl',
                          kw: { Create: 1, Say: 1, Print: 1, For: 1, from: 1, to: 1, End: 1, If: 1, Else: 1, While: 1, Function: 1, Class: 1, Return: 1, Set: 1, 'in': 1, each: 1, and: 1, or: 1, not: 1, 'new': 1 },
                          lines: ['Create greeting = "Hello, EPL"', 'Say greeting', 'Say "Squares from 1 to 5:"', 'For i from 1 to 5', '    Say i * i', 'End'] },
                        { key: 'Python', file: 'hello.py',
                          kw: { 'for': 1, 'in': 1, def: 1, 'class': 1, 'return': 1, 'if': 1, 'else': 1, 'while': 1, 'import': 1, True: 1, False: 1, None: 1 },
                          lines: ["greeting = 'Hello, EPL'", 'print(greeting)', "print('Squares from 1 to 5:')", 'for i in range(1, (5) + 1):', '    print((i * i))', ''] },
                        { key: 'JavaScript', file: 'hello.js',
                          kw: { 'let': 1, 'const': 1, 'var': 1, 'for': 1, 'function': 1, 'class': 1, 'return': 1, 'if': 1, 'else': 1, 'while': 1, 'new': 1, 'true': 1, 'false': 1, 'null': 1 },
                          lines: ['let greeting = "Hello, EPL";', 'console.log(greeting);', 'console.log("Squares from 1 to 5:");', 'for (let i = 1; i <= 5; i += 1) {', '  console.log((i * i));', '}'] }
                    ];

                    function esc(s) { return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }
                    function hlGen(line, kw) {
                        var out = '', re = /(#.*$|\/\/.*$)|("(?:[^"\\]|\\.)*"|'(?:[^'\\]|\\.)*')|(\b\d+(?:\.\d+)?\b)|([A-Za-z_]\w*)|(\s+)|([^\sA-Za-z0-9"']+)/g, m;
                        while ((m = re.exec(line))) {
                            if (m[1]) out += '<span class="c-dim">' + esc(m[1]) + '</span>';
                            else if (m[2]) out += '<span class="c-str">' + esc(m[2]) + '</span>';
                            else if (m[3]) out += '<span class="c-num">' + esc(m[3]) + '</span>';
                            else if (m[4]) {
                                var w = m[4], nx = line.charAt(re.lastIndex);
                                if (kw[w]) out += '<span class="c-kw">' + w + '</span>';
                                else if (nx === '(') out += '<span class="c-fn">' + w + '</span>';
                                else out += '<span class="c-id">' + w + '</span>';
                            } else if (m[5]) out += m[5];
                            else if (m[6]) out += '<span class="c-dim">' + esc(m[6]) + '</span>';
                        }
                        return out;
                    }

                    var tabsHtml = '';
                    LANGS.forEach(function (L, i) { tabsHtml += '<button class="ros-tab' + (i === 0 ? ' on' : '') + '" type="button" role="tab" data-i="' + i + '"><p>' + L.key + '</p></button>'; });
                    mount.innerHTML =
                      '<div class="ros-head"><div class="ros-dots"><i></i><i></i><i></i></div>' +
                        '<span class="ros-file" id="ros-file">hello.epl</span>' +
                        '<div class="ros-tabs" id="ros-tabs" role="tablist">' + tabsHtml + '</div></div>' +
                      '<div class="ros-code" id="ros-code"></div>' +
                      '<div class="ros-foot"><span class="ros-run">Output ▸ <b>Hello, EPL</b> · Squares from 1 to 5: · 1 4 9 16 25</span>' +
                        '<span class="ros-badge"><p>identical in every target</p></span></div>';

                    var tabsEl = document.getElementById('ros-tabs');
                    var codeEl = document.getElementById('ros-code');
                    var fileEl = document.getElementById('ros-file');

                    var cur = 0, auto = true, timer = null, started = false, inView = false;
                    function render(i, animate) {
                        cur = i; var L = LANGS[i]; fileEl.textContent = L.file;
                        codeEl.innerHTML = L.lines.map(function (ln, ri) {
                            return '<span class="ros-row' + (animate ? ' morph' : '') + '" style="animation-delay:' + (ri * 45) + 'ms">' + (hlGen(ln, L.kw) || '&nbsp;') + '</span>';
                        }).join('');
                        Array.prototype.forEach.call(tabsEl.children, function (b, bi) { b.classList.toggle('on', bi === i); });
                    }
                    function clearTimer() { if (timer) { clearTimeout(timer); timer = null; } }
                    function tick() { if (!auto || !inView) { timer = null; return; } render((cur + 1) % LANGS.length, true); timer = setTimeout(tick, 3000); }
                    function startAuto() { if (auto && inView && !timer) timer = setTimeout(tick, 2600); }
                    function stopAuto() { auto = false; clearTimer(); }

                    tabsEl.addEventListener('click', function (e) {
                        var b = e.target.closest('.ros-tab'); if (!b) return;
                        stopAuto(); render(+b.getAttribute('data-i'), !reduce);
                    });

                    if (reduce) { render(0, false); return; }
                    render(0, false);
                    new IntersectionObserver(function (es) {
                        es.forEach(function (e) {
                            inView = e.isIntersecting;
                            if (inView) { started = true; startAuto(); } else clearTimer();
                        });
                    }, { threshold: 0.4 }).observe(card);
                    document.addEventListener('visibilitychange', function () { if (document.hidden) clearTimer(); else startAuto(); });
                })();

                // ── EPL cursor-following particle field (Antigravity-style sparse scatter) ──
                var heroHost = document.querySelector('.hero');
                if (heroHost && !reduce) {
                    var cv = document.createElement('canvas');
                    cv.className = 'orbital';
                    cv.setAttribute('aria-hidden', 'true');
                    heroHost.insertBefore(cv, heroHost.firstChild);
                    var ctx = cv.getContext('2d');
                    var dpr = Math.min(window.devicePixelRatio || 1, 2);
                    var W = 0, H = 0, cx = 0, cy = 0;
                    var mouse = { x: 0.5, y: 0.5, has: false };
                    // Antigravity-style field: a SPARSE scatter of dashes with a diagonal
                    // warm→cool gradient (pink/red top-left → violet → blue bottom-right),
                    // denser on the left, that gently drift TOGETHER toward the cursor.
                    function dashColor(nx, ny) {
                        var warm = 1 - Math.min(1, nx * 0.42 + ny * 0.78);     // warm at top, cool at bottom
                        var hue = 214 + warm * 140;                            // 214 blue → 354 pink-red, via violet
                        return 'hsl(' + hue.toFixed(0) + ',' + (80 + warm * 10).toFixed(0) + '%,' + (62 - warm * 8).toFixed(0) + '%)';
                    }
                    var N = window.innerWidth < 720 ? 58 : 124;
                    var parts = [];
                    function spawnDash() {
                        var nx = Math.pow(Math.random(), 1.45);                 // left-biased density
                        var ny = Math.random();
                        return {
                            nx: nx, ny: ny,                                    // base position (normalised)
                            rot: (Math.random() - 0.5) * Math.PI,              // dash tilt
                            size: 1.6 + Math.random() * 1.3,                   // thickness
                            len: 5 + Math.random() * 9,                        // dash length
                            depth: 0.55 + Math.random() * 1.0,                 // parallax weight in the group-follow
                            bob: Math.random() * 6.283,                        // idle-float phase
                            bobs: 0.35 + Math.random() * 0.6,                  // idle-float speed
                            amp: 2.5 + Math.random() * 4.5,                    // idle-float amplitude
                            tw: Math.random() * 6.283,
                            tws: 0.5 + Math.random() * 0.9,                    // twinkle speed
                            alpha: 0.44 + Math.random() * 0.44,
                            col: dashColor(nx, ny)
                        };
                    }
                    for (var k = 0; k < N; k++) parts.push(spawnDash());
                    function resize() {
                        W = heroHost.clientWidth; H = heroHost.clientHeight;
                        cv.width = W * dpr; cv.height = H * dpr;
                        cv.style.width = W + 'px'; cv.style.height = H + 'px';
                        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
                        cx = W * 0.5; cy = H * 0.5;
                    }
                    resize();
                    window.addEventListener('resize', resize);
                    heroHost.addEventListener('mousemove', function (e) {
                        var r = heroHost.getBoundingClientRect();
                        mouse.x = (e.clientX - r.left) / r.width;
                        mouse.y = (e.clientY - r.top) / r.height;
                        mouse.has = true;
                    });
                    heroHost.addEventListener('mouseleave', function () { mouse.x = 0.5; mouse.y = 0.5; });
                    // touch: drag a finger and the field follows (no permission, no friction)
                    heroHost.addEventListener('touchmove', function (e) {
                        var tch = e.touches[0]; if (!tch) return;
                        var r = heroHost.getBoundingClientRect();
                        mouse.x = (tch.clientX - r.left) / r.width;
                        mouse.y = (tch.clientY - r.top) / r.height;
                        mouse.has = true;
                    }, { passive: true });
                    var t = 0, ox = 0, oy = 0, running = false, onScreen = true, pageVisible = true;
                    function loopActive() { return onScreen && pageVisible && !document.hidden; }
                    function draw() {
                        ctx.clearRect(0, 0, W, H);
                        // group-follow: the whole field eases TOWARD the cursor (offset from centre)
                        var amp = Math.min(W, H) * 0.075;
                        ox += ((mouse.x - 0.5) * amp * 2 - ox) * 0.045;        // slow, cohesive ease
                        oy += ((mouse.y - 0.5) * amp * 2 - oy) * 0.045;
                        for (var k = 0; k < parts.length; k++) {
                            var p = parts[k];
                            var fx = Math.sin(t * p.bobs + p.bob) * p.amp;     // gentle idle float
                            var fy = Math.cos(t * p.bobs * 0.9 + p.bob) * p.amp;
                            var x = p.nx * W + ox * p.depth + fx;
                            var y = p.ny * H + oy * p.depth + fy;
                            var tw = 0.55 + 0.45 * Math.sin(t * p.tws + p.tw); // twinkle
                            ctx.save();
                            ctx.translate(x, y);
                            ctx.rotate(p.rot);
                            ctx.globalAlpha = p.alpha * tw;
                            ctx.fillStyle = p.col;
                            var w = p.size, h = p.len;
                            if (ctx.roundRect) { ctx.beginPath(); ctx.roundRect(-w / 2, -h / 2, w, h, w / 2); ctx.fill(); }
                            else ctx.fillRect(-w / 2, -h / 2, w, h);
                            ctx.restore();
                        }
                        ctx.globalAlpha = 1;
                        t += 0.01;
                        if (loopActive()) requestAnimationFrame(draw);
                        else running = false;
                    }
                    function startLoop() { if (!running && loopActive()) { running = true; requestAnimationFrame(draw); } }
                    // pause the loop when the hero scrolls out of view or the tab is hidden
                    var heroVisIO = new IntersectionObserver(function (es) {
                        onScreen = es[0].isIntersecting; startLoop();
                    }, { threshold: 0 });
                    heroVisIO.observe(heroHost);
                    document.addEventListener('visibilitychange', function () {
                        pageVisible = !document.hidden; startLoop();
                    });
                    startLoop();
                }

                if (!reduce) {
                    // spotlight glow + 3D depth-tilt on cards
                    document.querySelectorAll('.spot').forEach(function (card) {
                        var isTarget = card.classList.contains('target');
                        var isAudience = card.classList.contains('audience-card');
                        var tilt = isTarget || isAudience;
                        // audience cards get a gentler, more editorial tilt than the dense target bento
                        var ax = isTarget ? -7 : -3.5, ay = isTarget ? 9 : 4.5, lift = isTarget ? -4 : -6;
                        card.addEventListener('mousemove', function (e) {
                            var r = card.getBoundingClientRect();
                            var mx = e.clientX - r.left, my = e.clientY - r.top;
                            card.style.setProperty('--mx', mx + 'px');
                            card.style.setProperty('--my', my + 'px');
                            if (tilt) {
                                var rx = ((my / r.height) - 0.5) * ax;
                                var ry = ((mx / r.width) - 0.5) * ay;
                                card.style.transform = 'translateY(' + lift + 'px) rotateX(' + rx + 'deg) rotateY(' + ry + 'deg)';
                            }
                        });
                        if (tilt) card.addEventListener('mouseleave', function () { card.style.transform = ''; });
                    });
                    var heroEl = document.querySelector('.hero');
                    if (heroEl) heroEl.addEventListener('mousemove', function (e) {
                        var r = heroEl.getBoundingClientRect();
                        heroEl.style.setProperty('--hx', (e.clientX - r.left) + 'px');
                        heroEl.style.setProperty('--hy', (e.clientY - r.top) + 'px');
                    });
                    document.querySelectorAll('.mag-group a').forEach(function (b) {
                        b.addEventListener('mousemove', function (e) {
                            var r = b.getBoundingClientRect();
                            var x = e.clientX - r.left - r.width / 2, y = e.clientY - r.top - r.height / 2;
                            b.style.transform = 'translate(' + (x * 0.18) + 'px,' + (y * 0.28) + 'px)';
                        });
                        b.addEventListener('mouseleave', function () { b.style.transform = ''; });
                    });
                }

                var btn = document.getElementById('copyBtn');
                if (btn) btn.addEventListener('click', function () {
                    navigator.clipboard.writeText('pip install eplang').then(function () {
                        var prev = btn.textContent; btn.textContent = 'Copied';
                        setTimeout(function () { btn.textContent = prev; }, 1600);
                    });
                });

                // ── Embedded live playground: editor + Run + output, against the Azure API ──
                (function setupPlayground() {
                    var mount = document.getElementById('pg-mount');
                    var run = document.getElementById('pg-run');
                    if (!mount || !run) return;
                    var API = 'https://epl-playground.azurewebsites.net/api/run';
                    var SEED = [
                        'Create greeting = "Hello, EPL"',
                        'Say greeting',
                        '',
                        'Say "Squares from 1 to 5:"',
                        'For i from 1 to 5',
                        '    Say i + " squared is " + (i * i)',
                        'End'
                    ].join('\n');

                    var ed = document.createElement('textarea');
                    ed.className = 'pg-editor';
                    ed.setAttribute('spellcheck', 'false');
                    ed.setAttribute('aria-label', 'EPL code editor');
                    ed.value = SEED;
                    mount.appendChild(ed);

                    var outWrap = document.createElement('div');
                    outWrap.className = 'pg-out-wrap';
                    var head = document.createElement('div');
                    head.className = 'pg-out-head';
                    head.innerHTML = '<span>Output</span><span class="pg-status"></span>';
                    var out = document.createElement('pre');
                    out.className = 'pg-out empty';
                    out.textContent = 'Press Run to execute.';
                    outWrap.appendChild(head);
                    outWrap.appendChild(out);
                    mount.appendChild(outWrap);
                    var status = head.querySelector('.pg-status');

                    var busy = false;
                    function setOut(text, isErr) {
                        out.classList.remove('empty');
                        out.classList.toggle('err', !!isErr);
                        out.textContent = text;
                    }
                    function execute() {
                        if (busy) return;
                        var code = ed.value;
                        if (!code.trim()) { setOut('Write some EPL first, then press Run.', false); return; }
                        busy = true;
                        run.setAttribute('aria-busy', 'true');
                        status.textContent = '';
                        var warm = setTimeout(function () {
                            status.textContent = 'Warming up the server… first run can take ~20s';
                        }, 1500);
                        fetch(API, { method: 'POST', headers: { 'Content-Type': 'text/plain;charset=UTF-8' }, body: JSON.stringify({ code: code }) })
                            .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
                            .then(function (res) {
                                var d = res.d || {};
                                if (d.error) { setOut(d.error, true); }
                                else { setOut((d.output != null && d.output !== '') ? d.output : '(no output)', false); }
                            })
                            .catch(function () {
                                setOut('Could not reach the playground server. It may be waking up — try again in a moment, or open the full playground.', true);
                            })
                            .then(function () {
                                clearTimeout(warm);
                                status.textContent = '';
                                busy = false;
                                run.removeAttribute('aria-busy');
                            });
                    }
                    run.addEventListener('click', execute);
                    ed.addEventListener('keydown', function (e) {
                        if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') { e.preventDefault(); execute(); }
                    });
                })();
            })();
        End
    End
End


Route "/terms" shows
    Page "Terms of Service — EPL"
        Description "Terms of Service for EPL, the English Programming Language. Operated by Abneesh Singh. Payments via Razorpay and Lemon Squeezy."
        Stylesheet
                :root{--ink:#FFFFFF;--paper:#111113;--muted:#5F6066;--ink2:#2A2A2E;
                    --line:rgba(17,17,19,.1);--line-soft:rgba(17,17,19,.05);--accent:#007DF3;--navy:#0E1A32;
                    --gut:clamp(20px,5vw,44px);--logo:url("data:image/png;base64,")}
                *{box-sizing:border-box}
                html{scroll-behavior:smooth}
                body{margin:0;background:var(--ink);color:var(--paper);line-height:1.66;
                    font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
                    -webkit-font-smoothing:antialiased;letter-spacing:-.011em}
                .container{max-width:100%!important;margin:0!important;padding:0!important;width:100%}
                p{margin:0}
                a{color:var(--accent);text-decoration:none}
                a:hover{text-decoration:underline}
                ::selection{background:var(--paper);color:#fff}
                .lnav{position:sticky;top:0;z-index:10;display:flex;align-items:center;justify-content:space-between;
                    padding:16px var(--gut);border-bottom:1px solid var(--line-soft);
                    background:rgba(255,255,255,.82);backdrop-filter:saturate(160%) blur(14px)}
                .lbrand a{display:inline-flex;align-items:center;gap:10px;font-weight:800;font-size:20px;
                    letter-spacing:-.03em;color:var(--paper)}
                .lbrand a:hover{text-decoration:none}
                .lbrand a::before{content:'';width:26px;height:28px;background:var(--logo) center/contain no-repeat}
                .lnav-right{display:flex;align-items:center;gap:22px}
                .lnav-right > a{font-size:14px;font-weight:500;color:var(--muted)}
                .lnav-right > a:hover{color:var(--paper);text-decoration:none}
                .lnav-cta-wrap a{color:#fff;background:var(--paper);padding:9px 18px;border-radius:999px;font-weight:600;font-size:14px}
                .lnav-cta-wrap a:hover{background:var(--navy);text-decoration:none}
                .legal{max-width:760px;margin:0 auto;padding:clamp(46px,7vw,90px) var(--gut) 40px}
                .eyebrow{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:500;
                    letter-spacing:.28em;text-transform:uppercase;color:var(--accent)}
                .legal h1{font-size:clamp(2.1rem,5vw,3.2rem);font-weight:800;letter-spacing:-.035em;
                    line-height:1.04;margin:14px 0 8px;color:var(--paper)}
                .updated{color:var(--muted);font-size:14px;margin-bottom:18px}
                .intro{font-size:1.12rem;line-height:1.62;color:var(--ink2);margin-bottom:8px}
                .lh2{font-size:1.28rem;font-weight:700;letter-spacing:-.02em;margin:40px 0 12px;color:var(--paper)}
                .legal p{color:var(--ink2);font-size:1.02rem;margin:0 0 14px}
                .legal .ul{margin:4px 0 16px;display:flex;flex-direction:column;gap:9px}
                .legal .li{position:relative;padding-left:22px;color:var(--ink2);font-size:1.02rem;line-height:1.6}
                .legal .li::before{content:'';position:absolute;left:3px;top:.62em;width:7px;height:7px;
                    border-radius:50%;background:var(--accent)}
                .legal .li p{display:inline}
                .legal strong{color:var(--paper);font-weight:600}
                .box{background:#F6F6F7;border:1px solid var(--line);border-radius:14px;
                    padding:18px 22px;margin:8px 0 14px;color:var(--muted);font-size:.97rem}
                .box a{font-weight:600}
                .lfoot{border-top:1px solid var(--line);margin-top:24px;padding:38px var(--gut);
                    display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;
                    max-width:880px;margin-left:auto;margin-right:auto;color:var(--muted);font-size:13px}
                .lfoot a{color:var(--muted)}
                .lfoot-links{display:flex;gap:20px;flex-wrap:wrap}
                .lfoot p{display:inline}
                @media(max-width:560px){.lnav-right > a{display:none}}
                
        End
