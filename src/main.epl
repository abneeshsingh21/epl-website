        Note: ── Audience (personas) ──────────────────────────────────────
        Section class "section" id "audience"
            Div class "wrap"
                Div class "sec-head"
                    Div class "eyebrow reveal"
                        Text "Built for everyone"
                    End
                    Div class "sec-h reveal dly-1"
                        Text "From classrooms "
                        Span class "g"
                            Text "to production."
                        End
                    End
                End

                Div class "audience-grid"
                    Div class "audience-card spot reveal"
                        Div class "audience-icon" id "ico-students"
                        End
                        Div class "audience-title"
                            Text "Students & Beginners"
                        End
                        Div class "audience-desc"
                            Text "No semicolons. No curly braces. No cryptic symbols. EPL reads like the pseudocode you already write on whiteboards — but it actually runs, compiles, and ships to eight targets."
                        End
                        Div class "audience-tag"
                            Text "Zero-friction onboarding"
                        End
                    End

                    Div class "audience-card spot reveal dly-1"
                        Div class "audience-icon" id "ico-educators"
                        End
                        Div class "audience-title"
                            Text "Educators & Institutions"
                        End
                        Div class "audience-desc"
                            Text "Teach algorithms, data structures, and systems design without losing half the semester to syntax. Students write working code on day one, and the same code compiles to native binaries for capstone projects."
                        End
                        Div class "audience-tag"
                            Text "Curriculum-ready"
                        End
                    End

                    Div class "audience-card spot reveal dly-2"
                        Div class "audience-icon" id "ico-developers"
                        End
                        Div class "audience-title"
                            Text "Professional Developers"
                        End
                        Div class "audience-desc"
                            Text "Prototype in minutes, iterate with a REPL, then ship to any target — server, browser, mobile, or embedded. A full language server, gradual type checker, and 22-package ecosystem back you in production."
                        End
                        Div class "audience-tag"
                            Text "Production-grade tooling"
                        End
                    End

                    Div class "audience-card spot reveal dly-3"
                        Div class "audience-icon" id "ico-ai"
                        End
                        Div class "audience-title"
                            Text "AI & Automation"
                        End
                        Div class "audience-desc"
                            Text "LLMs generate EPL with fewer hallucinations than brace-heavy languages. Plain-English syntax means AI-written code is human-readable by default — no post-processing, no style guide enforcement."
                        End
                        Div class "audience-tag"
                            Text "AI-native syntax"
                        End
                    End
                End
            End
