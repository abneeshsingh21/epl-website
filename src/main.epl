        Note: ── Motion system (progressive enhancement only) ─────────────
        Script
            (function () {
                var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

                // ── Audience icons: professional inline line-icons (replace emoji) ──
                (function setAudienceIcons() {
                    var P = 'http://www.w3.org/2000/svg';
                    function svg(paths) {
                        var s = '<svg xmlns="' + P + '" viewBox="0 0 24 24" aria-hidden="true">' + paths + '</svg>';
                        return s;
                    }
                    var ICONS = {
                        // graduation cap — students & beginners
                        'ico-students': svg('<path d="M2 8.5 12 4l10 4.5-10 4.5L2 8.5Z"/><path d="M6 10.5V15c0 1.5 2.7 3 6 3s6-1.5 6-3v-4.5"/><path d="M22 8.5V14"/>'),
                        // presentation board — educators & institutions
                        'ico-educators': svg('<rect x="3" y="4" width="18" height="12" rx="1.5"/><path d="M12 16v4"/><path d="M8 20h8"/><path d="M7.5 11.5 10 9l2 2 3-3.5"/>'),
                        // terminal/tools — professional developers
                        'ico-developers': svg('<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 9l3 3-3 3"/><path d="M13 15h4"/>'),
                        // chip/AI — AI & automation
                        'ico-ai': svg('<rect x="6.5" y="6.5" width="11" height="11" rx="2"/><path d="M9.5 9.5h5v5h-5z"/><path d="M9 3v2M15 3v2M9 19v2M15 19v2M3 9h2M3 15h2M19 9h2M19 15h2"/>')
                    };
                    Object.keys(ICONS).forEach(function (id) {
                        var el = document.getElementById(id);
                        if (el) el.innerHTML = ICONS[id];
                    });
                })();

                // ── Hidey glass nav (Antigravity-style): glass on scroll, hide down / show up ──
                var nav = document.getElementById('nav');
                var prog = document.querySelector('.scroll-progress');
                var lastY = 0, ticking = false;
                function onScroll() {
                    var sc = window.scrollY || document.documentElement.scrollTop;
                    if (nav) {
                        nav.classList.toggle('scrolled', sc > 36);
                        var hide = sc > 140 && sc > lastY + 4;
                        var show = sc < lastY - 4 || sc < 140;
                        if (hide && !nav.classList.contains('open')) nav.classList.add('hidden');
                        else if (show) nav.classList.remove('hidden');
                    }
                    if (prog) {
                        var h = document.documentElement.scrollHeight - window.innerHeight;
                        prog.style.transform = 'scaleX(' + (h > 0 ? sc / h : 0) + ')';
                    }
                    lastY = sc < 0 ? 0 : sc;
                    ticking = false;
                }
                window.addEventListener('scroll', function () {
                    if (!ticking) { requestAnimationFrame(onScroll); ticking = true; }
                }, { passive: true });
                onScroll();

                // ── Mobile nav: hamburger toggles the slide-in menu ──
                var navToggle = document.getElementById('navToggle');
                if (navToggle && nav) {
                    navToggle.setAttribute('role', 'button');
                    navToggle.setAttribute('tabindex', '0');
                    navToggle.setAttribute('aria-label', 'Toggle navigation menu');
                    function toggleMenu() { nav.classList.toggle('open'); }
                    navToggle.addEventListener('click', toggleMenu);
                    navToggle.addEventListener('keydown', function (e) {
                        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleMenu(); }
                    });
                    nav.querySelectorAll('.nav-links a, .nav-cta-wrap a').forEach(function (a) {
                        a.addEventListener('click', function () { nav.classList.remove('open'); });
                    });
                }

                function countUp(el) {
                    var raw = el.getAttribute('data-raw') || el.textContent.trim();
                    el.setAttribute('data-raw', raw);
                    var m = raw.match(/[\d,]+/);
                    if (!m) return;
                    var target = parseInt(m[0].replace(/,/g, ''), 10);
                    var prefix = raw.slice(0, m.index), suffix = raw.slice(m.index + m[0].length);
                    if (reduce) { el.textContent = prefix + target.toLocaleString() + suffix; return; }
                    var dur = 1500, t0 = null;
                    function tick(t) {
                        if (!t0) t0 = t;
                        var p = Math.min((t - t0) / dur, 1);
                        var e = 1 - Math.pow(1 - p, 3);
                        el.textContent = prefix + Math.floor(e * target).toLocaleString() + suffix;
                        if (p < 1) requestAnimationFrame(tick);
                    }
                    requestAnimationFrame(tick);
                }

                var io = new IntersectionObserver(function (entries) {
                    entries.forEach(function (en) {
                        if (en.isIntersecting) {
                            en.target.classList.add('in');
                            if (en.target.classList.contains('count')) countUp(en.target);
                            io.unobserve(en.target);
                        }
                    });
                }, { threshold: 0.16, rootMargin: '0px 0px -40px 0px' });
                document.querySelectorAll('.reveal, .count').forEach(function (el) { io.observe(el); });

                // ── word-level pull-up: split .pull-words into per-word spans ──
                // Reproduces the old WordsPullUpMultiStyle output in the motion layer.
                // Source stays semantic (plain text + styled spans), so if this JS never
                // runs the copy is still fully visible — no opacity:0 trap.
                Array.prototype.forEach.call(document.querySelectorAll('.pull-words'), function (host) {
                    var wrap = document.createElement('span');
                    wrap.className = 'native-words-wrapper';
                    var n = 0;
                    function emit(text, cls) {
                        text.split(/\s+/).forEach(function (w) {
                            if (!w) return;
                            if (n > 0) wrap.appendChild(document.createTextNode(' '));
                            var s = document.createElement('span');
                            s.className = 'native-pull-up' + (cls ? ' ' + cls : '');
                            s.style.transitionDelay = (n * 0.1) + 's';
                            if (reduce) s.classList.add('visible');
                            s.textContent = w;
                            wrap.appendChild(s);
                            n++;
                        });
                    }
                    Array.prototype.forEach.call(host.childNodes, function (node) {
                        if (node.nodeType === 3) emit(node.textContent, '');
                        else if (node.nodeType === 1) emit(node.textContent, node.className);
                    });
                    host.textContent = '';
                    host.appendChild(wrap);
                });

                var wio = new IntersectionObserver(function (entries) {
                    entries.forEach(function (en) { if (en.isIntersecting) en.target.classList.add('visible'); });
                }, { threshold: 0.1 });
                document.querySelectorAll('.native-pull-up').forEach(function (el) { wio.observe(el); });

                // ── EPL particle galaxy-vortex (Antigravity signature, EPL-branded palette) ──
                var heroHost = document.querySelector('.hero');
                if (heroHost && !reduce) {
                    var cv = document.createElement('canvas');
                    cv.className = 'orbital';
                    cv.setAttribute('aria-hidden', 'true');
                    heroHost.insertBefore(cv, heroHost.firstChild);
                    var ctx = cv.getContext('2d');
                    var dpr = Math.min(window.devicePixelRatio || 1, 2);
                    var W = 0, H = 0, cx = 0, cy = 0;
                    var mouse = { x: 0.5, y: 0.46, has: false };
                    // Antigravity-style multicolour confetti: blue-led brand palette
                    // plus festive accent hues, scattered broadly and floating gently.
                    var COLORS = ['#007DF3', '#2EA0FF', '#5BB8FF', '#1E88FF', '#7C5CFF',
                                  '#B14EFF', '#FF5C7A', '#FF9F45', '#FFD23F', '#21C7A8'];
                    var N = window.innerWidth < 720 ? 110 : 230;
                    var parts = [];
                    function spawnDash() {
                        // radial bias: keep the dead-centre clear for the headline, densest mid-field
                        return {
                            rr: 0.13 + Math.pow(Math.random(), 0.55) * 0.74, // normalised radius (0.13..0.87)
                            ang: Math.random() * Math.PI * 2,
                            rot: Math.random() * Math.PI,                     // dash orientation
                            drift: (Math.random() - 0.5) * 0.9,              // slow per-dash angular drift
                            rise: 0.5 + Math.random() * 1.3,                  // breathing speed
                            spin: (Math.random() - 0.5) * 0.4,               // own slow rotation
                            size: 1.5 + Math.random() * 1.7,                  // thickness
                            len: 4 + Math.random() * 9,                       // dash length
                            col: COLORS[(Math.random() * COLORS.length) | 0],
                            alpha: 0.32 + Math.random() * 0.5,
                            tw: Math.random() * 6.283,
                            tws: 0.6 + Math.random() * 1.3                    // twinkle speed
                        };
                    }
                    for (var k = 0; k < N; k++) parts.push(spawnDash());
                    function resize() {
                        W = heroHost.clientWidth; H = heroHost.clientHeight;
                        cv.width = W * dpr; cv.height = H * dpr;
                        cv.style.width = W + 'px'; cv.style.height = H + 'px';
                        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
                        cx = W * 0.5; cy = H * 0.5;
                    }
                    resize();
                    window.addEventListener('resize', resize);
                    heroHost.addEventListener('mousemove', function (e) {
                        var r = heroHost.getBoundingClientRect();
                        mouse.x = (e.clientX - r.left) / r.width;
                        mouse.y = (e.clientY - r.top) / r.height;
                        mouse.has = true;
                    });
                    var t = 0, running = false, onScreen = true, pageVisible = true;
                    function loopActive() { return onScreen && pageVisible && !document.hidden; }
                    function draw() {
                        var maxR = Math.hypot(W, H) * 0.52;
                        ctx.clearRect(0, 0, W, H);
                        var px = mouse.has ? (mouse.x - 0.5) * 52 : 0;
                        var py = mouse.has ? (mouse.y - 0.5) * 52 : 0;
                        for (var k = 0; k < parts.length; k++) {
                            var p = parts[k];
                            var a = p.ang + t * p.drift * 0.12;                 // slow individual drift
                            var breathe = 1 + 0.055 * Math.sin(t * p.rise + p.tw); // gentle radial float
                            var rad = p.rr * maxR * breathe;
                            var depth = p.rr;                                   // outer dashes parallax more
                            var x = cx + Math.cos(a) * rad + px * depth;
                            var y = cy + Math.sin(a) * rad + py * depth;
                            var tw = 0.4 + 0.6 * Math.sin(t * p.tws + p.tw);    // twinkle
                            ctx.save();
                            ctx.translate(x, y);
                            ctx.rotate(p.rot + t * p.spin * 0.5);
                            ctx.globalAlpha = p.alpha * tw;
                            ctx.fillStyle = p.col;
                            var w = p.size, h = p.len;
                            if (ctx.roundRect) { ctx.beginPath(); ctx.roundRect(-w / 2, -h / 2, w, h, w / 2); ctx.fill(); }
                            else ctx.fillRect(-w / 2, -h / 2, w, h);
                            ctx.restore();
                        }
                        ctx.globalAlpha = 1;
                        t += 0.006;
                        if (loopActive()) requestAnimationFrame(draw);
                        else running = false;
                    }
                    function startLoop() { if (!running && loopActive()) { running = true; requestAnimationFrame(draw); } }
                    // pause the loop when the hero scrolls out of view or the tab is hidden
                    var heroVisIO = new IntersectionObserver(function (es) {
                        onScreen = es[0].isIntersecting; startLoop();
                    }, { threshold: 0 });
                    heroVisIO.observe(heroHost);
                    document.addEventListener('visibilitychange', function () {
                        pageVisible = !document.hidden; startLoop();
                    });
                    startLoop();
                }

                if (!reduce) {
                    // spotlight glow + 3D depth-tilt on cards
                    document.querySelectorAll('.spot').forEach(function (card) {
                        var tilt = card.classList.contains('target');
                        card.addEventListener('mousemove', function (e) {
                            var r = card.getBoundingClientRect();
                            var mx = e.clientX - r.left, my = e.clientY - r.top;
                            card.style.setProperty('--mx', mx + 'px');
                            card.style.setProperty('--my', my + 'px');
                            if (tilt) {
                                var rx = ((my / r.height) - 0.5) * -7;
                                var ry = ((mx / r.width) - 0.5) * 9;
                                card.style.transform = 'translateY(-4px) rotateX(' + rx + 'deg) rotateY(' + ry + 'deg)';
                            }
                        });
                        if (tilt) card.addEventListener('mouseleave', function () { card.style.transform = ''; });
                    });
                    var heroEl = document.querySelector('.hero');
                    if (heroEl) heroEl.addEventListener('mousemove', function (e) {
                        var r = heroEl.getBoundingClientRect();
                        heroEl.style.setProperty('--hx', (e.clientX - r.left) + 'px');
                        heroEl.style.setProperty('--hy', (e.clientY - r.top) + 'px');
                    });
                    document.querySelectorAll('.mag-group a').forEach(function (b) {
                        b.addEventListener('mousemove', function (e) {
                            var r = b.getBoundingClientRect();
                            var x = e.clientX - r.left - r.width / 2, y = e.clientY - r.top - r.height / 2;
                            b.style.transform = 'translate(' + (x * 0.18) + 'px,' + (y * 0.28) + 'px)';
                        });
                        b.addEventListener('mouseleave', function () { b.style.transform = ''; });
                    });
                }

                var btn = document.getElementById('copyBtn');
                if (btn) btn.addEventListener('click', function () {
                    navigator.clipboard.writeText('pip install eplang').then(function () {
                        var prev = btn.textContent; btn.textContent = 'Copied';
                        setTimeout(function () { btn.textContent = prev; }, 1600);
                    });
                });

                // ── Embedded live playground: editor + Run + output, against the Azure API ──
                (function setupPlayground() {
                    var mount = document.getElementById('pg-mount');
                    var run = document.getElementById('pg-run');
                    if (!mount || !run) return;
                    var API = 'https://epl-playground.azurewebsites.net/api/run';
                    var SEED = [
                        'Create greeting = "Hello, EPL"',
                        'Say greeting',
                        '',
                        'Say "Squares from 1 to 5:"',
                        'For i from 1 to 5',
                        '    Say i + " squared is " + (i * i)',
                        'End'
                    ].join('\n');

                    var ed = document.createElement('textarea');
                    ed.className = 'pg-editor';
                    ed.setAttribute('spellcheck', 'false');
                    ed.setAttribute('aria-label', 'EPL code editor');
                    ed.value = SEED;
                    mount.appendChild(ed);

                    var outWrap = document.createElement('div');
                    outWrap.className = 'pg-out-wrap';
                    var head = document.createElement('div');
                    head.className = 'pg-out-head';
                    head.innerHTML = '<span>Output</span><span class="pg-status"></span>';
                    var out = document.createElement('pre');
                    out.className = 'pg-out empty';
                    out.textContent = 'Press Run to execute.';
                    outWrap.appendChild(head);
                    outWrap.appendChild(out);
                    mount.appendChild(outWrap);
                    var status = head.querySelector('.pg-status');

                    var busy = false;
                    function setOut(text, isErr) {
                        out.classList.remove('empty');
                        out.classList.toggle('err', !!isErr);
                        out.textContent = text;
                    }
                    function execute() {
                        if (busy) return;
                        var code = ed.value;
                        if (!code.trim()) { setOut('Write some EPL first, then press Run.', false); return; }
                        busy = true;
                        run.setAttribute('aria-busy', 'true');
                        status.textContent = '';
                        var warm = setTimeout(function () {
                            status.textContent = 'Warming up the server… first run can take ~20s';
                        }, 1500);
                        fetch(API, { method: 'POST', headers: { 'Content-Type': 'text/plain;charset=UTF-8' }, body: JSON.stringify({ code: code }) })
                            .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, d: d }; }); })
                            .then(function (res) {
                                var d = res.d || {};
                                if (d.error) { setOut(d.error, true); }
                                else { setOut((d.output != null && d.output !== '') ? d.output : '(no output)', false); }
                            })
                            .catch(function () {
                                setOut('Could not reach the playground server. It may be waking up — try again in a moment, or open the full playground.', true);
                            })
                            .then(function () {
                                clearTimeout(warm);
                                status.textContent = '';
                                busy = false;
                                run.removeAttribute('aria-busy');
                            });
                    }
                    run.addEventListener('click', execute);
                    ed.addEventListener('keydown', function (e) {
                        if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') { e.preventDefault(); execute(); }
                    });
                })();
            })();
        End
    End
End


Route "/terms" shows
    Page "Terms of Service — EPL"
        Description "Terms of Service for EPL, the English Programming Language. Operated by Abneesh Singh. Payments via Razorpay and Lemon Squeezy."
        Stylesheet
                :root{--ink:#FFFFFF;--paper:#111113;--muted:#5F6066;--ink2:#2A2A2E;
                    --line:rgba(17,17,19,.1);--line-soft:rgba(17,17,19,.05);--accent:#007DF3;--navy:#0E1A32;
                    --gut:clamp(20px,5vw,44px);--logo:url("data:image/png;base64,")}
                *{box-sizing:border-box}
                html{scroll-behavior:smooth}
                body{margin:0;background:var(--ink);color:var(--paper);line-height:1.66;
                    font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
                    -webkit-font-smoothing:antialiased;letter-spacing:-.011em}
                .container{max-width:100%!important;margin:0!important;padding:0!important;width:100%}
                p{margin:0}
                a{color:var(--accent);text-decoration:none}
                a:hover{text-decoration:underline}
                ::selection{background:var(--paper);color:#fff}
                .lnav{position:sticky;top:0;z-index:10;display:flex;align-items:center;justify-content:space-between;
                    padding:16px var(--gut);border-bottom:1px solid var(--line-soft);
                    background:rgba(255,255,255,.82);backdrop-filter:saturate(160%) blur(14px)}
                .lbrand a{display:inline-flex;align-items:center;gap:10px;font-weight:800;font-size:20px;
                    letter-spacing:-.03em;color:var(--paper)}
                .lbrand a:hover{text-decoration:none}
                .lbrand a::before{content:'';width:26px;height:28px;background:var(--logo) center/contain no-repeat}
                .lnav-right{display:flex;align-items:center;gap:22px}
                .lnav-right > a{font-size:14px;font-weight:500;color:var(--muted)}
                .lnav-right > a:hover{color:var(--paper);text-decoration:none}
                .lnav-cta-wrap a{color:#fff;background:var(--paper);padding:9px 18px;border-radius:999px;font-weight:600;font-size:14px}
                .lnav-cta-wrap a:hover{background:var(--navy);text-decoration:none}
                .legal{max-width:760px;margin:0 auto;padding:clamp(46px,7vw,90px) var(--gut) 40px}
                .eyebrow{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:500;
                    letter-spacing:.28em;text-transform:uppercase;color:var(--accent)}
                .legal h1{font-size:clamp(2.1rem,5vw,3.2rem);font-weight:800;letter-spacing:-.035em;
                    line-height:1.04;margin:14px 0 8px;color:var(--paper)}
                .updated{color:var(--muted);font-size:14px;margin-bottom:18px}
                .intro{font-size:1.12rem;line-height:1.62;color:var(--ink2);margin-bottom:8px}
                .lh2{font-size:1.28rem;font-weight:700;letter-spacing:-.02em;margin:40px 0 12px;color:var(--paper)}
                .legal p{color:var(--ink2);font-size:1.02rem;margin:0 0 14px}
                .legal .ul{margin:4px 0 16px;display:flex;flex-direction:column;gap:9px}
                .legal .li{position:relative;padding-left:22px;color:var(--ink2);font-size:1.02rem;line-height:1.6}
                .legal .li::before{content:'';position:absolute;left:3px;top:.62em;width:7px;height:7px;
                    border-radius:50%;background:var(--accent)}
                .legal .li p{display:inline}
                .legal strong{color:var(--paper);font-weight:600}
                .box{background:#F6F6F7;border:1px solid var(--line);border-radius:14px;
                    padding:18px 22px;margin:8px 0 14px;color:var(--muted);font-size:.97rem}
                .box a{font-weight:600}
                .lfoot{border-top:1px solid var(--line);margin-top:24px;padding:38px var(--gut);
                    display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:14px;
                    max-width:880px;margin-left:auto;margin-right:auto;color:var(--muted);font-size:13px}
                .lfoot a{color:var(--muted)}
                .lfoot-links{display:flex;gap:20px;flex-wrap:wrap}
                .lfoot p{display:inline}
                @media(max-width:560px){.lnav-right > a{display:none}}
                
        End
        Div class "lnav"
            Div class "lbrand"
                Link "EPL" to "/"
            End
            Div class "lnav-right"
                Link "Docs" to "https://abneeshsingh21.github.io/EPL/"
                Link "Back to site" to "/"
                Div class "lnav-cta-wrap"
                    Link "Install" to "/#install"
                End
            End
        End
        Div class "legal"

            Div class "eyebrow"
                Text "Legal · Effective 16 June 2026"
            End
            Heading "Terms of Service"
            Div class "updated"
                Text "Last updated 16 June 2026"
            End
            Div class "intro"
                Text "These Terms govern your access to and use of the EPL website and any related products, downloads, documentation, sponsorships, or paid offerings (the Services), operated by Abneesh Singh, an individual sole proprietor based in India (referred to as EPL, we, or us). By accessing the site or using the Services, you agree to these Terms. If you do not agree, please do not use the Services."
            End
            Div class "lh2"
                Text "1. The EPL software"
            End
            Text "EPL (the English Programming Language) is open-source software distributed under the Apache License 2.0. Your use of the software itself is governed by that license, which is provided with the source code. The website, the EPL branding, and any paid offerings are provided under these Terms in addition to the software license."
            Div class "lh2"
                Text "2. Eligibility"
            End
            Text "You must be at least 18 years old, or the age of majority in your jurisdiction, to make a purchase or enter into a paid arrangement. By transacting, you confirm that you meet this requirement."
            Div class "lh2"
                Text "3. Accuracy of information"
            End
            Text "Where a purchase, sponsorship, or download requires you to provide information, you agree to provide accurate, current, and complete details."
            Div class "lh2"
                Text "4. Payments"
            End
            Text "Paid offerings, such as sponsorships, support, or other products, are processed by trusted third-party payment providers:"
            Div class "ul"
                Div class "li"
                    Text "Razorpay, for payments within India"
                End
                Div class "li"
                    Text "Lemon Squeezy, for international payments"
                End
            End
            Text "We do not collect or store your full card or banking details. Those are handled directly by the relevant provider under its own terms and security standards. Prices are shown at the point of purchase and may include applicable taxes. By completing a purchase, you authorise the provider to charge the amount shown."
            Div class "lh2"
                Text "5. Refunds"
            End
            Text "Refunds, where applicable, are governed by our Refund and Cancellation Policy, available at /refund."
            Div class "lh2"
                Text "6. Acceptable use"
            End
            Text "You agree not to misuse the Services. In particular, you will not attempt to disrupt or compromise the site, infringe the rights of others, use the Services for unlawful purposes, or misrepresent your affiliation with EPL. Use of the open-source software is permitted under the Apache-2.0 license."
            Div class "lh2"
                Text "7. Intellectual property"
            End
            Text "The EPL name, logo, and website content are the property of Abneesh Singh, except for the open-source software (licensed under Apache-2.0) and any third-party materials. You may not use the EPL branding in a way that implies endorsement or affiliation without prior written permission."
            Div class "lh2"
                Text "8. Disclaimers"
            End
            Text "The Services are provided on an as-is and as-available basis, without warranties of any kind, whether express or implied, to the maximum extent permitted by law. We do not warrant that the Services will be uninterrupted, secure, or error-free."
            Div class "lh2"
                Text "9. Limitation of liability"
            End
            Text "To the maximum extent permitted by law, Abneesh Singh shall not be liable for any indirect, incidental, special, or consequential damages arising from your use of the Services. Where liability cannot be excluded, it is limited to the total amount you paid, if any, during the three months preceding the claim."
            Div class "lh2"
                Text "10. Changes to these Terms"
            End
            Text "We may update these Terms from time to time. Material changes will be reflected by the Last updated date above. Your continued use of the Services after changes take effect constitutes acceptance of the revised Terms."
            Div class "lh2"
                Text "11. Governing law"
            End
            Text "These Terms are governed by and construed in accordance with the laws of India. Any disputes arising from these Terms or the Services shall be subject to the exclusive jurisdiction of the competent courts in India."
            Div class "lh2"
                Text "12. Contact"
            End
            Div class "box"
                Text "Questions about these Terms? Email us at singhabneesh250@gmail.com."
            End

        End
        Div class "lfoot"
            Span class "c"
                Text "© 2024–2026 Abneesh Singh · EPL · Apache-2.0"
            End
            Div class "lfoot-links"
                Link "Terms" to "/terms"
                Link "Privacy" to "/privacy"
                Link "Refund" to "/refund"
                Link "Contact" to "mailto:singhabneesh250@gmail.com"
            End
        End
    End
End

